/* 全局样式 */
page {
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', 'Roboto', 'Oxygen', 'Ubuntu', 'Cantarell', 'Fira Sans', 'Droid Sans', 'Helvetica Neue', sans-serif;
  font-size: 28rpx;
  background-color: #F5F5F5;
  color: #333;
}

/* 通用容器 */
.container {
  padding: 20rpx;
}

/* 按钮样式 */
.btn-primary {
  background-color: #FF6B35;
  color: #fff;
  border-radius: 8rpx;
  padding: 20rpx 40rpx;
  font-size: 30rpx;
  border: none;
}

.btn-primary:active {
  opacity: 0.8;
}

.btn-secondary {
  background-color: #FFF;
  color: #FF6B35;
  border: 2rpx solid #FF6B35;
  border-radius: 8rpx;
  padding: 20rpx 40rpx;
  font-size: 30rpx;
}

/* 卡片样式 */
.card {
  background-color: #FFF;
  border-radius: 12rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.08);
}

/* 标签样式 */
.tag {
  display: inline-block;
  padding: 8rpx 16rpx;
  border-radius: 6rpx;
  font-size: 24rpx;
  margin-right: 12rpx;
}

.tag-primary {
  background-color: #FFF3E0;
  color: #FF6B35;
}

.tag-success {
  background-color: #E8F5E9;
  color: #4CAF50;
}

.tag-warning {
  background-color: #FFF3E0;
  color: #FF9800;
}

/* 文本样式 */
.text-primary {
  color: #FF6B35;
}

.text-secondary {
  color: #999;
}

.text-muted {
  color: #CCC;
}

/* 边距 */
.mt-10 {
  margin-top: 10rpx;
}

.mt-20 {
  margin-top: 20rpx;
}

.mb-10 {
  margin-bottom: 10rpx;
}

.mb-20 {
  margin-bottom: 20rpx;
}

/* Flex布局 */
.flex {
  display: flex;
}

.flex-center {
  display: flex;
  align-items: center;
  justify-content: center;
}

.flex-between {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.flex-1 {
  flex: 1;
}

/* 空状态 */
.empty {
  text-align: center;
  padding: 80rpx 0;
  color: #999;
}

.empty image {
  width: 200rpx;
  height: 200rpx;
  margin-bottom: 20rpx;
}
