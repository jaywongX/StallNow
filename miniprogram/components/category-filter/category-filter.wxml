<scroll-view scroll-x class="category-filter" enable-flex>
  <view
    class="category-item {{selectedId === '' ? 'active' : ''}}"
    data-id=""
    bindtap="onSelect"
  >
    全部
  </view>
  <view
    wx:for="{{categories}}"
    wx:key="_id"
    class="category-item {{selectedId === item._id ? 'active' : ''}}"
    data-id="{{item._id}}"
    bindtap="onSelect"
  >
    <text class="icon" wx:if="{{item.icon}}">{{item.icon}}</text>
    {{item.name}}
  </view>
</scroll-view>
