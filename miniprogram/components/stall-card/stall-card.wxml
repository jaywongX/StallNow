<wxs src="stall-card.wxs" module="utils" />

<view class="stall-card" bindtap="onTap">
  <!-- 图片 -->
  <image
    class="stall-image"
    src="{{stall.images && stall.images.length > 0 ? stall.images[0] : '/images/default-stall.png'}}"
    mode="aspectFill"
  />

  <!-- 信息区 -->
  <view class="stall-info">
    <!-- 展示名和距离 -->
    <view class="stall-name-row">
      <view class="stall-name">{{stall.displayName}}</view>
      <view class="stall-distance" wx:if="{{showDistance && stall.distance}}">
        <text class="distance-icon">📍</text>
        <text class="distance-text">{{utils.formatDistance(stall.distance)}}</text>
      </view>
    </view>

    <!-- 分类和可信度标签 -->
    <view class="tags">
      <text class="tag tag-primary">{{stall.categoryName || '其他'}}</text>
      <text class="tag tag-secondary" wx:if="{{showReliability}}">{{utils.getReliabilityInfo(stall).icon}} {{utils.getReliabilityInfo(stall).text}}</text>
    </view>

    <!-- 商品信息 -->
    <view class="info-row" wx:if="{{utils.hasGoodsTags(stall)}}">
      <text class="icon">🏷️</text>
      <text class="label">商品：</text>
      <text class="value">{{utils.getGoodsTagsText(stall)}}</text>
    </view>

    <!-- 位置信息 -->
    <view class="info-row">
      <text class="icon">📍</text>
      <text class="label">地址：</text>
      <text class="value">{{stall.address || stall.location.name || '位置未设置'}}</text>
    </view>

    <!-- 出摊时间 -->
    <view class="info-row">
      <text class="icon">🕐</text>
      <text class="label">时间：</text>
      <text class="value">{{utils.getScheduleText(stall)}}</text>
      <text class="note" wx:if="{{stall.schedule && stall.schedule.note}}">{{stall.schedule.note}}</text>
    </view>
  </view>
</view>
