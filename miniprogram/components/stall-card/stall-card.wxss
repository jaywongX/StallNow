.stall-card {
  background-color: #FFF;
  border-radius: 12rpx;
  overflow: hidden;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.08);
}

.stall-image {
  width: 100%;
  height: 300rpx;
  display: block;
}

.stall-info {
  padding: 24rpx;
}

.stall-name-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12rpx;
}

.stall-name {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  flex: 1;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.stall-distance {
  display: flex;
  align-items: center;
  background: linear-gradient(135deg, #4A90E2 0%, #357ABD 100%);
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
  flex-shrink: 0;
  margin-left: 16rpx;
}

.distance-icon {
  font-size: 20rpx;
  margin-right: 4rpx;
}

.distance-text {
  font-size: 22rpx;
  color: #FFF;
  font-weight: 500;
}

.tags {
  display: flex;
  flex-wrap: wrap;
  margin-bottom: 16rpx;
}

.tag {
  display: inline-block;
  padding: 6rpx 16rpx;
  border-radius: 6rpx;
  font-size: 22rpx;
  margin-right: 12rpx;
  margin-bottom: 8rpx;
}

.tag-primary {
  background-color: #FFF3E0;
  color: #FF6B35;
}

.tag-secondary {
  background-color: #F5F5F5;
  color: #666;
}

.info-row {
  display: flex;
  align-items: flex-start;
  font-size: 26rpx;
  color: #666;
  margin-bottom: 10rpx;
  line-height: 1.5;
}

.info-row .icon {
  margin-right: 4rpx;
  flex-shrink: 0;
}

.info-row .label {
  color: #999;
  flex-shrink: 0;
}

.info-row .value {
  flex: 1;
  color: #333;
}

.info-row .note {
  color: #999;
  margin-left: 8rpx;
  font-size: 24rpx;
}
