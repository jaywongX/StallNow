.time-filter {
  white-space: nowrap;
  padding: 16rpx 0;
  background-color: #FFF;
  border-top: 1rpx solid #F0F0F0;
}

.time-item {
  display: inline-block;
  padding: 10rpx 28rpx;
  margin-right: 12rpx;
  border-radius: 28rpx;
  font-size: 26rpx;
  background-color: #F5F5F5;
  color: #666;
  flex-shrink: 0;
}

.time-item.active {
  background-color: #FF6B35;
  color: #FFF;
}
