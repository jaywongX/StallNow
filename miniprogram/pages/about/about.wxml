<view class="about-container">
  <!-- 头部信息 -->
  <view class="header">
    <image class="logo" src="/images/default-stall.png" mode="aspectFit" />
    <view class="app-name">{{appName}}</view>
    <view class="version">版本 {{version}}</view>
  </view>

  <!-- 内容区域 -->
  <view class="content">
    <view class="section" wx:for="{{sections}}" wx:key="index">
      <!-- 一级标题 -->
      <view class="section-title">{{item.title}}</view>
      
      <!-- 普通内容 -->
      <view wx:if="{{item.content}}" class="section-content">
        <text class="content-text">{{item.content}}</text>
      </view>
      
      <!-- 简单列表 (通过 hasSimpleList 标记判断) -->
      <view wx:if="{{item.hasSimpleList}}" class="simple-list">
        <view class="list-item" wx:for="{{item.items}}" wx:for-item="listItem" wx:key="index">
          <text class="item-bullet">•</text>
          <text class="item-text">{{listItem}}</text>
        </view>
      </view>
      
      <!-- 子项目 (通过 hasSubsection 标记判断) -->
      <view wx:if="{{item.hasSubsection}}" class="subsection" wx:for="{{item.items}}" wx:for-item="sub" wx:key="index">
        <view class="subsection-title">{{sub.subtitle}}</view>
        <view class="subsection-content">
          <text class="content-text">{{sub.content}}</text>
        </view>
      </view>
    </view>

    <!-- 底部说明 -->
    <view class="footer">
      <text class="footer-text">版本 {{version}} | 最后更新：2026年1月1日</text>
    </view>
  </view>
</view>
