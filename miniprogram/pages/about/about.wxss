.about-container {
  min-height: 100vh;
  background-color: #F5F5F5;
}

.header {
  background-color: #FFF;
  padding: 60rpx 30rpx;
  text-align: center;
  margin-bottom: 20rpx;
}

.logo {
  width: 160rpx;
  height: 160rpx;
  border-radius: 32rpx;
  margin-bottom: 24rpx;
  background-color: #FFF3E0;
}

.app-name {
  font-size: 40rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 12rpx;
}

.version {
  font-size: 26rpx;
  color: #999;
}

.content {
  background-color: #FFF;
  padding: 40rpx 30rpx;
  margin-bottom: 20rpx;
}

.content-text {
  display: block;
  font-size: 26rpx;
  line-height: 1.8;
  color: #333;
  white-space: pre-wrap;
  word-wrap: break-word;
}
