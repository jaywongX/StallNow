<!-- 引入辅助函数 -->
<wxs src="./admin.wxs" module="helper" />

<!-- 标签栏 -->
<view class="tab-bar">
  <view
    class="tab-item {{activeTab === 'applications' ? 'active' : ''}}"
    data-tab="applications"
    bindtap="onTabChange"
  >
    入驻申请
  </view>
  <view
    class="tab-item {{activeTab === 'proxyApply' ? 'active' : ''}}"
    data-tab="proxyApply"
    bindtap="onTabChange"
  >
    代录入
  </view>
  <view
    class="tab-item {{activeTab === 'recommendations' ? 'active' : ''}}"
    data-tab="recommendations"
    bindtap="onTabChange"
  >
    游客推荐
  </view>
  <view
    class="tab-item {{activeTab === 'claimAudit' ? 'active' : ''}}"
    data-tab="claimAudit"
    bindtap="onTabChange"
  >
    认领审核
  </view>
  <view
    class="tab-item {{activeTab === 'stalls' ? 'active' : ''}}"
    data-tab="stalls"
    bindtap="onTabChange"
  >
    地摊管理
  </view>
  <view
    class="tab-item {{activeTab === 'feedbacks' ? 'active' : ''}}"
    data-tab="feedbacks"
    bindtap="onTabChange"
  >
    反馈管理
  </view>
</view>

<!-- 状态筛选 - 只在摊位管理和反馈管理显示 -->
<view class="status-filter" wx:if="{{activeTab === 'stalls' || activeTab === 'feedbacks'}}">
  <view
    class="filter-item {{statusFilter == 0 ? 'active' : ''}}"
    data-status="0"
    bindtap="onStatusFilter"
  >
    {{activeTab === 'stalls' ? '已上架' : '待处理'}}
  </view>
  <view
    class="filter-item {{statusFilter == 1 ? 'active' : ''}}"
    data-status="1"
    bindtap="onStatusFilter"
  >
    {{activeTab === 'stalls' ? '已下架' : '已标记'}}
  </view>
  <view
    class="filter-item {{statusFilter == 2 ? 'active' : ''}}"
    data-status="2"
    bindtap="onStatusFilter"
  >
    {{activeTab === 'stalls' ? '已下线' : '已处理'}}
  </view>
</view>

<!-- 代录入入口 -->
<view class="proxy-container" wx:if="{{activeTab === 'proxyApply'}}">
  <!-- 页面标题 -->
  <view class="page-header">
    <text class="header-title">代录入摊位</text>
    <text class="header-subtitle">帮助商贩录入信息，录入后直接上架</text>
  </view>
  
  <!-- 表单 -->
  <view class="form-section">
    <!-- Step 1: 摊位类型 -->
    <view class="form-group">
      <view class="group-header">
        <text class="group-title">商品类型</text>
        <text class="required">*</text>
      </view>
      <view class="category-grid">
        <view 
          wx:for="{{categories}}" 
          wx:key="_id"
          class="category-item {{proxyForm.categoryId === item._id ? 'active' : ''}}"
          data-id="{{item._id}}"
          data-name="{{item.name}}"
          bindtap="onProxyCategorySelect"
        >
          <text class="category-icon">{{item.icon}}</text>
          <text class="category-name">{{item.name}}</text>
        </view>
      </view>
      <text wx:if="{{errors.category}}" class="error-text">{{errors.category}}</text>
    </view>

    <!-- Step 2: 常见商品 -->
    <view class="form-group" wx:if="{{proxyForm.categoryId}}">
      <view class="group-header">
        <text class="group-title">常见商品（多选）</text>
        <text class="required">*</text>
      </view>
      <view class="tags-container">
        <view 
          wx:for="{{currentGoodsOptions}}" 
          wx:key="*this"
          class="tag-item {{helper.includes(proxyForm.goodsTags, item) ? 'active' : ''}}"
          data-tag="{{item}}"
          bindtap="onProxyGoodsTagSelect"
        >
          {{item}}
        </view>
      </view>
      <text class="tags-hint">已选择 {{proxyForm.goodsTags.length}}/5 个</text>
      
      <!-- 自定义商品输入 -->
      <view class="custom-goods-section">
        <text class="custom-goods-label">没有找到？自定义商品：</text>
        <view class="custom-goods-input-row">
          <input 
            class="custom-goods-input"
            placeholder="输入商品名称"
            value="{{customGoodsInput}}"
            bindinput="onCustomGoodsInput"
            maxlength="10"
          />
          <view class="custom-goods-add-btn" bindtap="onProxyAddCustomGoods">添加</view>
        </view>
      </view>
      
      <text wx:if="{{errors.goods}}" class="error-text">{{errors.goods}}</text>
    </view>
    
    <!-- Step 3: 定位位置（必选） -->
    <view class="form-group">
      <view class="group-header">
        <text class="group-title">摊位定位</text>
        <text class="required">*</text>
      </view>
      
      <view class="location-selector" bindtap="onProxySelectLocation">
        <view wx:if="{{!proxyForm.location}}" class="location-empty">
          <text class="location-icon">📍</text>
          <text class="location-text">点击选择摊位位置</text>
          <text class="location-hint">在地图上标记摊位位置</text>
        </view>
        
        <view wx:if="{{proxyForm.location}}" class="location-selected">
          <view class="location-header">
            <text class="location-name">{{proxyForm.location.name || '已选择位置'}}</text>
            <text class="location-change">重新选择</text>
          </view>
          <text class="location-address">{{proxyForm.location.address}}</text>
          <view class="location-coords">
            <text>纬度: {{proxyForm.location.latitude.toFixed(4)}}  经度: {{proxyForm.location.longitude.toFixed(4)}}</text>
          </view>
        </view>
      </view>
      <text class="input-hint">点击上方区域，在地图上选择摊位位置</text>
      <text wx:if="{{errors.location}}" class="error-text">{{errors.location}}</text>
    </view>

    <!-- Step 4: 常出没区域（可选） -->
    <view class="form-group">
      <view class="group-header">
        <text class="group-title">常出没区域</text>
        <text class="optional">（选填）</text>
      </view>
      <input 
        class="form-input"
        placeholder="例如：老街夜市、万达广场附近"
        value="{{proxyForm.address}}"
        data-field="address"
        bindinput="onProxyInput"
      />
      <text class="input-hint">填写常出没的大致区域，帮助用户更容易找到摊位</text>
    </view>
    
    <!-- Step 5: 外观特征 -->
    <view class="form-group">
      <view class="group-header">
        <text class="group-title">外观特征</text>
        <text class="optional">（选填）</text>
      </view>
      <input 
        class="form-input"
        placeholder="例如：红色推车、黄色招牌"
        value="{{proxyForm.landmark}}"
        data-field="landmark"
        bindinput="onProxyInput"
      />
    </view>
    
    <!-- Step 6: 出摊时间 -->
    <view class="form-group">
      <view class="group-header">
        <text class="group-title">一般什么时候出摊？</text>
        <text class="required">*</text>
      </view>
      <view class="schedule-grid">
        <view 
          wx:for="{{scheduleOptions}}" 
          wx:key="id"
          class="schedule-item {{helper.includes(proxyForm.scheduleTypes, item.id) ? 'active' : ''}}"
          data-id="{{item.id}}"
          bindtap="onProxyScheduleSelect"
        >
          <text class="schedule-icon">{{item.icon}}</text>
          <text class="schedule-name">{{item.name}}</text>
        </view>
      </view>
      
      <!-- 自定义时间段选择（选择"不固定"时显示） -->
      <view class="custom-time-section" wx:if="{{helper.includes(proxyForm.scheduleTypes, 'unfixed')}}">
        <text class="custom-time-label">选择出摊时间段：</text>
        <view class="time-picker-row">
          <picker mode="selector" range="{{timePickerRange}}" bindchange="onCustomTimeStartChange">
            <view class="time-picker-btn">
              <text class="time-text">{{proxyForm.customTimeStart || '开始时间'}}</text>
              <text class="time-icon">▼</text>
            </view>
          </picker>
          <text class="time-separator">至</text>
          <picker mode="selector" range="{{timePickerRange}}" bindchange="onCustomTimeEndChange">
            <view class="time-picker-btn">
              <text class="time-text">{{proxyForm.customTimeEnd || '结束时间'}}</text>
              <text class="time-icon">▼</text>
            </view>
          </picker>
        </view>
      </view>
      
      <text wx:if="{{errors.schedule}}" class="error-text">{{errors.schedule}}</text>
    </view>
    
    <!-- Step 7: 价格区间（选填） -->
    <view class="form-group">
      <view class="group-header">
        <text class="group-title">价格区间</text>
        <text class="optional">（选填）</text>
      </view>
      <text class="input-hint">告诉顾客大概的价格范围，帮助快速决策</text>
      <view class="price-grid">
        <view 
          wx:for="{{priceOptions}}" 
          wx:key="id"
          class="price-item {{proxyForm.priceRangeType === item.id ? 'active' : ''}}"
          data-id="{{item.id}}"
          data-display="{{item.display}}"
          bindtap="onProxyPriceSelect"
        >
          <text class="price-name">{{item.name}}</text>
        </view>
      </view>
      
      <!-- 自定义价格输入（选择"自定义"时显示） -->
      <view class="custom-price-section" wx:if="{{proxyForm.priceRangeType === 'custom'}}">
        <view class="price-input-row">
          <input 
            class="price-input"
            type="digit"
            placeholder="最低"
            value="{{proxyForm.customPriceMin}}"
            bindinput="onProxyCustomPriceMinInput"
            maxlength="5"
          />
          <text class="price-separator">-</text>
          <input 
            class="price-input"
            type="digit"
            placeholder="最高"
            value="{{proxyForm.customPriceMax}}"
            bindinput="onProxyCustomPriceMaxInput"
            maxlength="5"
          />
          <text class="price-unit">元</text>
        </view>
      </view>
    </view>
    
    <!-- Step 8: 摊位照片（选填） -->
    <view class="form-group">
      <view class="group-header">
        <text class="group-title">摊位照片</text>
        <text class="optional">（选填，最多3张）</text>
      </view>
      <!-- 合规提示 -->
      <view class="compliance-notice">
        <text class="notice-icon">💡</text>
        <view class="notice-content">
          <text class="notice-title">请上传摊位实拍照片</text>
          <text class="notice-text">照片请不要包含：价格标签、收款码、促销广告</text>
        </view>
      </view>
      <view class="image-upload-container">
        <view 
          class="image-item" 
          wx:for="{{proxyForm.images}}" 
          wx:key="index"
          data-index="{{index}}"
          bindtap="onProxyPreviewImage"
        >
          <image src="{{item}}" mode="aspectFill" />
          <view class="delete-btn" data-index="{{index}}" catchtap="onProxyDeleteImage">×</view>
        </view>
        <view 
          class="upload-btn-large"
          bindtap="onProxyUploadImage"
          wx:if="{{proxyForm.images.length < 3}}"
        >
          <text class="icon">📷</text>
          <text class="text">上传照片</text>
          <text class="sub-text">{{proxyForm.images.length}}/3</text>
        </view>
      </view>
      <text class="input-hint">上传摊位实拍照片，帮助大家认出摊位</text>
    </view>

    <!-- Step 9: 摊位称呼（选填） -->
    <view class="form-group">
      <view class="group-header">
        <text class="group-title">摊位称呼</text>
        <text class="optional">（选填）</text>
      </view>
      <input 
        class="form-input"
        placeholder="例如：老王烧烤、广场手工摊"
        value="{{proxyForm.displayName}}"
        data-field="displayName"
        bindinput="onProxyInput"
      />
      <view class="compliance-notice-small">
        <text class="notice-icon-small">💡</text>
        <text class="notice-text-small">请不要包含价格信息、促销用语、联系方式</text>
      </view>
      <text class="input-hint">不填将由系统自动生成</text>
    </view>
    
    <!-- Step 10: 联系方式（选填） -->
    <view class="form-group">
      <view class="group-header">
        <text class="group-title">联系方式</text>
        <text class="optional">（选填，仅用于用户联系摊主）</text>
      </view>
      <view class="contact-inputs">
        <input 
          class="form-input"
          type="number"
          maxlength="11"
          placeholder="手机号码"
          value="{{proxyForm.phone}}"
          data-field="phone"
          bindinput="onProxyInput"
        />
      </view>
    </view>
    
    <!-- Step 11: 备注 -->
    <view class="form-group">
      <view class="group-header">
        <text class="group-title">备注</text>
        <text class="optional">（选填）</text>
      </view>
      <textarea 
        class="form-textarea"
        placeholder="其他需要说明的信息"
        value="{{proxyForm.remark}}"
        data-field="remark"
        bindinput="onProxyInput"
      />
    </view>
  </view>
  
  <!-- 提交按钮 -->
  <view class="submit-section">
    <button class="submit-btn" bindtap="onProxySubmit">提交录入</button>
    <text class="submit-tips">提交后摊位将直接上架，状态为"营业中（待认领）"</text>
  </view>
  
  <!-- 隐藏的 canvas 用于图片压缩 -->
  <canvas canvas-id="compressCanvas" class="compress-canvas"></canvas>
</view>

<!-- 入驻申请列表 -->
<view class="content-container" wx:if="{{activeTab === 'applications'}}">
  <view class="application-card" wx:for="{{applications}}" wx:key="_id">
    <!-- 申请人信息 -->
    <view class="applicant-info">
      <image class="avatar" src="{{item.userInfo.avatarUrl || '/images/default-avatar.png'}}" mode="aspectFill" />
      <view class="info">
        <text class="nickname">{{item.userInfo.nickName || '未知用户'}}</text>
        <text class="submit-time">{{item.submitTime}}</text>
      </view>
      <text class="status status-pending">待审核</text>
    </view>

    <!-- 申请详情 -->
    <view class="application-detail">
      <!-- 基本信息 -->
      <view class="detail-section">
        <view class="section-title">基本信息</view>
        <view class="detail-row">
          <text class="detail-label">展示名称</text>
          <text class="detail-value">{{item.stallData.displayName || '未命名'}}</text>
        </view>
        <view class="detail-row">
          <text class="detail-label">商品类型</text>
          <text class="detail-value">{{item.stallData.categoryName || '-'}}</text>
        </view>
        <view class="detail-row">
          <text class="detail-label">外观特征</text>
          <text class="detail-value">{{item.stallData.landmark || '-'}}</text>
        </view>
        <view class="detail-row" wx:if="{{item.stallData.vendorName}}">
          <text class="detail-label">商家名称</text>
          <text class="detail-value">{{item.stallData.vendorName}}</text>
        </view>
      </view>

      <!-- 位置信息 -->
      <view class="detail-section">
        <view class="section-title">位置信息</view>
        <view class="detail-row">
          <text class="detail-label">出摊位置</text>
          <text class="detail-value">{{item.stallData.address || '-'}}</text>
        </view>
        <!-- 地图展示 -->
        <view class="map-container" wx:if="{{item.stallData.location}}">
          <map
            class="location-map"
            latitude="{{item.stallData.location.latitude}}"
            longitude="{{item.stallData.location.longitude}}"
            markers="{{item.mapMarkers}}"
            show-location="{{false}}"
            enable-zoom="{{true}}"
            enable-scroll="{{true}}"
          />
        </view>
        <view class="detail-row" wx:if="{{item.stallData.location}}">
          <text class="detail-label">坐标</text>
          <text class="detail-value coords">{{item.stallData.location.latitude.toFixed(6)}}, {{item.stallData.location.longitude.toFixed(6)}}</text>
        </view>
      </view>

      <!-- 出摊时间 -->
      <view class="detail-section">
        <view class="section-title">出摊时间</view>
        <view class="detail-row">
          <text class="detail-label">时间类型</text>
          <text class="detail-value">{{item.stallData.schedule.display || '-'}}</text>
        </view>
        <view class="detail-row" wx:if="{{item.stallData.schedule.customTime}}">
          <text class="detail-label">自定义时段</text>
          <text class="detail-value">{{item.stallData.schedule.customTime}}</text>
        </view>
      </view>

      <!-- 联系方式 -->
      <view class="detail-section" wx:if="{{item.stallData.contact.hasContact}}">
        <view class="section-title">联系方式</view>
        <view class="detail-row" wx:if="{{item.stallData.contact.phone}}">
          <text class="detail-label">电话</text>
          <text class="detail-value">{{item.stallData.contact.phone}}</text>
        </view>
        <view class="detail-row" wx:if="{{item.stallData.contact.wechatQR}}">
          <text class="detail-label">微信二维码</text>
          <text class="detail-value link" bindtap="onPreviewImage" data-url="{{item.stallData.contact.wechatQR}}">点击查看</text>
        </view>
      </view>

      <!-- 图片 -->
      <view class="detail-section" wx:if="{{item.stallData.images && item.stallData.images.length > 0}}">
        <view class="section-title">摊位照片 ({{item.stallData.images.length}}张)</view>
        <view class="image-list">
          <image
            wx:for="{{item.stallData.images}}"
            wx:for-item="img"
            wx:key="index"
            class="stall-image"
            src="{{img}}"
            mode="aspectFill"
            bindtap="onPreviewStallImage"
            data-images="{{item.stallData.images}}"
            data-current="{{img}}"
          />
        </view>
      </view>
    </view>

    <!-- 操作按钮 -->
    <view class="card-footer">
      <view
        class="btn btn-danger"
        data-id="{{item._id}}"
        data-action="reject"
        bindtap="onAuditApplication"
      >
        拒绝
      </view>
      <view
        class="btn btn-primary"
        data-id="{{item._id}}"
        data-action="approve"
        bindtap="onAuditApplication"
      >
        通过
      </view>
    </view>
  </view>

  <!-- 空状态 -->
  <view class="empty" wx:if="{{applications.length === 0 && !loading}}">
    <image src="/images/empty.png" mode="aspectFit" />
    <text>暂无入驻申请</text>
  </view>
</view>

<!-- 游客推荐列表 -->
<view class="content-container" wx:if="{{activeTab === 'recommendations'}}">
  <view class="card" wx:for="{{recommendations}}" wx:key="_id">
    <!-- 推荐人信息 -->
    <view class="applicant-info">
      <image class="avatar" src="{{item.recommenderInfo.avatarUrl || '/images/default-avatar.png'}}" mode="aspectFill" />
      <view class="info">
        <text class="nickname">{{item.recommenderInfo.nickName || '游客'}}</text>
        <text class="submit-time">推荐于 {{item.recommendedAt}}</text>
      </view>
      <text class="status status-pending">待审核</text>
    </view>

    <!-- 推荐详情 -->
    <view class="application-detail">
      <!-- 基本信息 -->
      <view class="detail-section">
        <view class="section-title">基本信息</view>
        <view class="detail-row">
          <text class="detail-label">摊位名称</text>
          <text class="detail-value">{{item.displayName || '未命名'}}</text>
        </view>
        <view class="detail-row">
          <text class="detail-label">商品类型</text>
          <text class="detail-value">{{item.categoryName || '-'}}</text>
        </view>
        <view class="detail-row">
          <text class="detail-label">外观特征</text>
          <text class="detail-value">{{item.landmark || '-'}}</text>
        </view>
        <view class="detail-row">
          <text class="detail-label">商品标签</text>
          <text class="detail-value">{{helper.join(item.goodsTags, '、')}}</text>
        </view>
      </view>

      <!-- 位置信息 -->
      <view class="detail-section">
        <view class="section-title">位置信息</view>
        <view class="detail-row">
          <text class="detail-label">推荐位置</text>
          <text class="detail-value">{{item.address || '-'}}</text>
        </view>
        <!-- 地图展示 -->
        <view class="map-container" wx:if="{{item.location}}">
          <map
            class="location-map"
            latitude="{{item.location.latitude}}"
            longitude="{{item.location.longitude}}"
            markers="{{item.mapMarkers}}"
            show-location="{{false}}"
            enable-zoom="{{true}}"
            enable-scroll="{{true}}"
          />
        </view>
      </view>

      <!-- 出摊时间 -->
      <view class="detail-section" wx:if="{{item.schedule.display}}">
        <view class="section-title">出摊时间</view>
        <view class="detail-row">
          <text class="detail-label">时间类型</text>
          <text class="detail-value">{{item.schedule.display}}</text>
        </view>
        <view class="detail-row" wx:if="{{item.schedule.customTime}}">
          <text class="detail-label">具体时段</text>
          <text class="detail-value">{{item.schedule.customTime}}</text>
        </view>
      </view>

      <!-- 价格区间 -->
      <view class="detail-section" wx:if="{{item.priceRange && item.priceRange.display}}">
        <view class="section-title">价格区间</view>
        <view class="detail-row">
          <text class="detail-label">价格范围</text>
          <text class="detail-value">{{item.priceRange.display}}</text>
        </view>
      </view>

      <!-- 联系方式 -->
      <view class="detail-section" wx:if="{{item.contact && item.contact.phone}}">
        <view class="section-title">联系方式</view>
        <view class="detail-row">
          <text class="detail-label">手机号码</text>
          <text class="detail-value">{{item.contact.phone}}</text>
        </view>
      </view>

      <!-- 图片 -->
      <view class="detail-section" wx:if="{{item.images && item.images.length > 0}}">
        <view class="section-title">摊位照片 ({{item.images.length}}张)</view>
        <view class="image-list">
          <image
            wx:for="{{item.images}}"
            wx:for-item="img"
            wx:key="index"
            class="stall-image"
            src="{{img}}"
            mode="aspectFill"
            bindtap="onPreviewStallImage"
            data-images="{{item.images}}"
            data-current="{{img}}"
          />
        </view>
      </view>
    </view>

    <!-- 操作按钮 -->
    <view class="card-footer">
      <view
        class="btn btn-danger"
        data-id="{{item._id}}"
        data-action="reject"
        bindtap="onAuditRecommendation"
      >
        拒绝
      </view>
      <view
        class="btn btn-primary"
        data-id="{{item._id}}"
        data-action="approve"
        bindtap="onAuditRecommendation"
      >
        通过
      </view>
    </view>
  </view>

  <!-- 空状态 -->
  <view class="empty" wx:if="{{recommendations.length === 0 && !loading}}">
    <image src="/images/empty.png" mode="aspectFit" />
    <text>暂无游客推荐</text>
  </view>
</view>

<!-- 地摊管理列表 -->
<view class="content-container" wx:if="{{activeTab === 'stalls'}}">
  <view class="card" wx:for="{{stalls}}" wx:key="_id">
    <view class="card-header">
      <text class="title">{{item.displayName}}</text>
      <view class="status-tags">
        <text class="status">{{item.status === 1 ? '已上架' : item.status === 2 ? '已下架' : '已下线'}}</text>
        <text wx:if="{{item.claimStatus === 'unclaimed'}}" class="status-unclaimed">待认领</text>
        <text wx:if="{{item.createdBy === 'admin_proxy'}}" class="status-proxy">代录</text>
      </view>
    </view>
    <view class="card-body">
      <view class="row">
        <text class="label">出摊位置：</text>
        <text class="value">{{item.address}}</text>
      </view>
      <view class="row">
        <text class="label">最后确认：</text>
        <text class="value">{{item.lastConfirmedAt || '-'}}</text>
      </view>
      <view class="row" wx:if="{{item.claimStatus === 'claimed' && item.claimedAt}}">
        <text class="label">认领时间：</text>
        <text class="value">{{item.claimedAt}}</text>
      </view>
    </view>
    <view class="card-footer">
      <view
        class="btn"
        data-id="{{item._id}}"
        data-action="{{item.status === 1 ? 'offline' : 'online'}}"
        bindtap="onStallAction"
      >
        {{item.status === 1 ? '下架' : '上架'}}
      </view>
    </view>
  </view>

  <!-- 空状态 -->
  <view class="empty" wx:if="{{stalls.length === 0 && !loading}}">
    <image src="/images/empty.png" mode="aspectFit" />
    <text>暂无地摊信息</text>
  </view>
</view>

<!-- 反馈管理列表 -->
<view class="content-container" wx:if="{{activeTab === 'feedbacks'}}">
  <view class="card" wx:for="{{feedbacks}}" wx:key="_id" wx:for-item="item" wx:for-index="idx">
    <view class="card-header">
      <text class="title" wx:if="{{item.source === 'user'}}">
        <text wx:if="{{item.type === 'feature'}}">功能建议</text>
        <text wx:elif="{{item.type === 'bug'}}">Bug反馈</text>
        <text wx:elif="{{item.type === 'content'}}">内容纠错</text>
        <text wx:else>其他反馈</text>
      </text>
      <text class="title" wx:else>
        <text wx:if="{{item.type === 'wrong_location'}}">位置不对</text>
        <text wx:elif="{{item.type === 'wrong_info'}}">商品变化</text>
        <text wx:elif="{{item.type === 'not_exist'}}">已不存在</text>
        <text wx:else>其他</text>
      </text>
      <text class="status" wx:if="{{item.status === 0}}">待处理</text>
      <text class="status" wx:elif="{{item.status === 1}}">已标记</text>
      <text class="status" wx:else>已处理</text>
    </view>
    <view class="card-body">
      <!-- 意见反馈显示内容 -->
      <view wx:if="{{item.source === 'user'}}">
        <view class="row">
          <text class="label">反馈内容：</text>
        </view>
        <view class="feedback-content">{{item.content || '无内容'}}</view>
        <view class="row" wx:if="{{item.contact}}">
          <text class="label">联系方式：</text>
          <text class="value">{{item.contact}}</text>
        </view>
      </view>
      <!-- 摊位反馈显示摊位ID -->
      <view wx:if="{{item.source === 'stall' && item.stallId}}">
        <view class="row">
          <text class="label">关联摊位：</text>
          <text class="value">{{item.stallId}}</text>
        </view>
      </view>
      <view class="row">
        <text class="label">反馈时间：</text>
        <text class="value">{{item.createTime}}</text>
      </view>
      <view class="row" wx:if="{{item.processedAt}}">
        <text class="label">处理时间：</text>
        <text class="value">{{item.processedAt}}</text>
      </view>
    </view>
    <view class="card-footer">
      <view
        class="btn btn-secondary"
        data-id="{{item._id}}"
        data-action="mark"
        bindtap="onHandleFeedback"
        wx:if="{{item.status === 0}}"
      >
        标记
      </view>
      <view
        class="btn btn-primary"
        data-id="{{item._id}}"
        data-action="process"
        bindtap="onHandleFeedback"
        wx:if="{{item.status === 0 || item.status === 1}}"
      >
        处理
      </view>
    </view>
  </view>

  <!-- 空状态 -->
  <view class="empty" wx:if="{{feedbacks.length === 0 && !loading}}">
    <image src="/images/empty.png" mode="aspectFit" />
    <text>暂无反馈信息</text>
  </view>
</view>

<!-- 加载状态 -->
<view class="loading" wx:if="{{loading}}">
  加载中...
</view>

