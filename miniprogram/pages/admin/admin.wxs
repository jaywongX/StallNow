// 辅助函数模块

// 检查数组是否包含指定值
function includes(array, value) {
  if (!array || !array.length) return false;
  return array.indexOf(value) > -1;
}

// 数组转字符串
function join(array, separator) {
  if (!array || !array.length) return '-';
  separator = separator || '、';
  var result = '';
  for (var i = 0; i < array.length; i++) {
    if (i > 0) {
      result += separator;
    }
    result += array[i];
  }
  return result;
}

module.exports = {
  includes: includes,
  join: join
};
