/* 标签栏 */
.tab-bar {
  display: flex;
  background-color: #FFF;
  border-bottom: 1rpx solid #F0F0F0;
}

.tab-item {
  flex: 1;
  text-align: center;
  padding: 24rpx;
  font-size: 28rpx;
  color: #666;
  position: relative;
}

.tab-item.active {
  color: #FF6B35;
  font-weight: bold;
}

.tab-item.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 60rpx;
  height: 4rpx;
  background-color: #FF6B35;
  border-radius: 2rpx;
}

/* 状态筛选 */
.status-filter {
  display: flex;
  background-color: #FFF;
  padding: 20rpx;
  border-bottom: 1rpx solid #F0F0F0;
}

.filter-item {
  flex: 1;
  text-align: center;
  padding: 12rpx;
  margin-right: 16rpx;
  background-color: #F5F5F5;
  border-radius: 6rpx;
  font-size: 24rpx;
  color: #666;
}

.filter-item:last-child {
  margin-right: 0;
}

.filter-item.active {
  background-color: #FF6B35;
  color: #FFF;
}

/* 内容容器 */
.content-container {
  padding: 20rpx;
  min-height: calc(100vh - 200rpx);
}

/* 卡片 */
.card {
  background-color: #FFF;
  border-radius: 12rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.08);
}

.card-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 20rpx;
}

.card-header .title {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
  flex: 1;
}

.card-header .status {
  padding: 6rpx 16rpx;
  background-color: #E8F5E9;
  color: #4CAF50;
  border-radius: 6rpx;
  font-size: 22rpx;
}

.status.status-pending {
  background-color: #FFF3E0;
  color: #FF9800;
}

.card-body .row {
  display: flex;
  align-items: center;
  margin-bottom: 12rpx;
  font-size: 26rpx;
}

.card-body .row:last-child {
  margin-bottom: 0;
}

.card-body .label {
  color: #999;
  width: 160rpx;
}

.card-body .value {
  flex: 1;
  color: #333;
}

.card-footer {
  display: flex;
  gap: 16rpx;
  margin-top: 20rpx;
}

.card-footer .btn {
  flex: 1;
  padding: 16rpx;
  text-align: center;
  border-radius: 6rpx;
  font-size: 26rpx;
  background-color: #F5F5F5;
  color: #666;
}

.card-footer .btn.btn-secondary {
  background-color: #FFF3E0;
  color: #FF9800;
}

.card-footer .btn.btn-primary {
  background-color: #FF6B35;
  color: #FFF;
}

.card-footer .btn.btn-danger {
  background-color: #FFEBEE;
  color: #F44336;
}

/* 空状态 */
.empty {
  text-align: center;
  padding: 120rpx 0;
}

.empty image {
  width: 240rpx;
  height: 240rpx;
  margin-bottom: 30rpx;
}

/* 加载状态 */
.loading {
  text-align: center;
  padding: 80rpx 0;
  color: #999;
}

/* 合规菜单 */
.compliance-menu {
  background-color: #FFF;
  border-radius: 12rpx;
  overflow: hidden;
}

.menu-item {
  display: flex;
  align-items: center;
  padding: 30rpx;
  border-bottom: 1rpx solid #F0F0F0;
  position: relative;
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-item:active {
  background-color: #F5F5F5;
}

.menu-icon {
  width: 80rpx;
  height: 80rpx;
  font-size: 40rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 24rpx;
}

.menu-content {
  flex: 1;
}

.menu-title {
  display: block;
  font-size: 30rpx;
  color: #333;
  font-weight: bold;
  margin-bottom: 8rpx;
}

.menu-desc {
  display: block;
  font-size: 24rpx;
  color: #999;
}

.menu-arrow {
  font-size: 40rpx;
  color: #CCC;
}

