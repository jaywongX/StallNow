/* 标签栏 */
.tab-bar {
  display: flex;
  background-color: #FFF;
  border-bottom: 1rpx solid #F0F0F0;
}

.tab-item {
  flex: 1;
  text-align: center;
  padding: 24rpx;
  font-size: 28rpx;
  color: #666;
  position: relative;
}

.tab-item.active {
  color: #FF6B35;
  font-weight: bold;
}

.tab-item.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 60rpx;
  height: 4rpx;
  background-color: #FF6B35;
  border-radius: 2rpx;
}

/* 状态筛选 */
.status-filter {
  display: flex;
  background-color: #FFF;
  padding: 20rpx;
  border-bottom: 1rpx solid #F0F0F0;
}

.filter-item {
  flex: 1;
  text-align: center;
  padding: 12rpx;
  margin-right: 16rpx;
  background-color: #F5F5F5;
  border-radius: 6rpx;
  font-size: 24rpx;
  color: #666;
}

.filter-item:last-child {
  margin-right: 0;
}

.filter-item.active {
  background-color: #FF6B35;
  color: #FFF;
}

/* 内容容器 */
.content-container {
  padding: 20rpx;
  min-height: calc(100vh - 200rpx);
}

/* 卡片 */
.card {
  background-color: #FFF;
  border-radius: 12rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.08);
}

.card-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 20rpx;
}

.card-header .title {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
  flex: 1;
}

.card-header .status {
  padding: 6rpx 16rpx;
  background-color: #E8F5E9;
  color: #4CAF50;
  border-radius: 6rpx;
  font-size: 22rpx;
}

.status.status-pending {
  background-color: #FFF3E0;
  color: #FF9800;
}

.card-body .row {
  display: flex;
  align-items: center;
  margin-bottom: 12rpx;
  font-size: 26rpx;
}

.card-body .row:last-child {
  margin-bottom: 0;
}

.card-body .label {
  color: #999;
  width: 160rpx;
}

.card-body .value {
  flex: 1;
  color: #333;
}

/* 反馈内容样式 */
.feedback-content {
  background-color: #f8f8f8;
  padding: 20rpx;
  border-radius: 8rpx;
  margin: 16rpx 0;
  color: #333;
  font-size: 28rpx;
  line-height: 1.6;
  word-break: break-all;
}

.card-footer {
  display: flex;
  gap: 16rpx;
  margin-top: 20rpx;
}

.card-footer .btn {
  flex: 1;
  padding: 16rpx;
  text-align: center;
  border-radius: 6rpx;
  font-size: 26rpx;
  background-color: #F5F5F5;
  color: #666;
}

.card-footer .btn.btn-secondary {
  background-color: #FFF3E0;
  color: #FF9800;
}

.card-footer .btn.btn-primary {
  background-color: #FF6B35;
  color: #FFF;
}

.card-footer .btn.btn-danger {
  background-color: #FFEBEE;
  color: #F44336;
}

/* 空状态 */
.empty {
  text-align: center;
  padding: 120rpx 0;
}

.empty image {
  width: 240rpx;
  height: 240rpx;
  margin-bottom: 30rpx;
}

/* 加载状态 */
.loading {
  text-align: center;
  padding: 80rpx 0;
  color: #999;
}

/* 申请卡片 */
.application-card {
  background-color: #FFF;
  border-radius: 12rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.08);
  overflow: hidden;
}

/* 申请人信息 */
.applicant-info {
  display: flex;
  align-items: center;
  padding: 24rpx;
  background: linear-gradient(135deg, #FF6B35 0%, #FF8C42 100%);
}

.applicant-info .avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  border: 4rpx solid rgba(255, 255, 255, 0.3);
  margin-right: 20rpx;
}

.applicant-info .info {
  flex: 1;
}

.applicant-info .nickname {
  display: block;
  font-size: 30rpx;
  color: #FFF;
  font-weight: bold;
  margin-bottom: 8rpx;
}

.applicant-info .submit-time {
  display: block;
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.8);
}

.applicant-info .status {
  padding: 8rpx 20rpx;
  background-color: rgba(255, 255, 255, 0.9);
  border-radius: 24rpx;
  font-size: 24rpx;
  color: #FF6B35;
}

/* 申请详情 */
.application-detail {
  padding: 20rpx;
}

.detail-section {
  margin-bottom: 24rpx;
  padding-bottom: 20rpx;
  border-bottom: 1rpx solid #F5F5F5;
}

.detail-section:last-child {
  margin-bottom: 0;
  padding-bottom: 0;
  border-bottom: none;
}

.section-title {
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 16rpx;
  padding-left: 16rpx;
  border-left: 8rpx solid #FF6B35;
}

.detail-row {
  display: flex;
  padding: 12rpx 0;
  font-size: 26rpx;
}

.detail-label {
  width: 160rpx;
  color: #999;
  flex-shrink: 0;
}

.detail-value {
  flex: 1;
  color: #333;
  word-break: break-all;
}

.detail-value.link {
  color: #FF6B35;
  text-decoration: underline;
}

/* 图片列表 */
.image-list {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.stall-image {
  width: 180rpx;
  height: 180rpx;
  border-radius: 8rpx;
}

/* 地图容器 */
.map-container {
  margin: 16rpx 0;
  border-radius: 12rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.1);
}

.location-map {
  width: 100%;
  height: 300rpx;
}

.detail-value.coords {
  font-family: monospace;
  font-size: 24rpx;
  color: #666;
}

/* 申请卡片底部 */
.application-card .card-footer {
  padding: 20rpx;
  background-color: #FAFAFA;
  border-top: 1rpx solid #F0F0F0;
}

/* ==================== 代录入页面样式 ==================== */

/* 代录入容器 */
.proxy-container {
  min-height: 100vh;
  background: #F5F5F5;
  padding-bottom: 60rpx;
}

/* 页面头部 */
.page-header {
  background: linear-gradient(135deg, #FF6B35 0%, #FF8F50 100%);
  padding: 60rpx 30rpx;
  text-align: center;
}

.header-title {
  display: block;
  font-size: 40rpx;
  font-weight: bold;
  color: #fff;
  margin-bottom: 12rpx;
}

.header-subtitle {
  display: block;
  font-size: 26rpx;
  color: rgba(255,255,255,0.8);
}

/* 表单区域 */
.form-section {
  padding: 30rpx;
}

.form-group {
  background: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 24rpx;
}

.group-header {
  display: flex;
  align-items: center;
  margin-bottom: 24rpx;
}

.group-title {
  font-size: 32rpx;
  font-weight: 500;
  color: #333;
}

.required {
  color: #FF6B35;
  margin-left: 8rpx;
  font-size: 28rpx;
}

.optional {
  color: #999;
  margin-left: 8rpx;
  font-size: 24rpx;
}

/* 表单输入 */
.form-input {
  width: 100%;
  height: 88rpx;
  background: #F8F8F8;
  border-radius: 12rpx;
  padding: 0 24rpx;
  font-size: 28rpx;
  color: #333;
  box-sizing: border-box;
}

.input-hint {
  display: block;
  font-size: 24rpx;
  color: #999;
  margin-top: 12rpx;
}

/* 错误提示 */
.error-text {
  display: block;
  font-size: 24rpx;
  color: #FF4D4F;
  margin-top: 12rpx;
}

/* 分类网格 */
.category-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
}

.category-item {
  width: calc(33.33% - 14rpx);
  background: #F8F8F8;
  border-radius: 12rpx;
  padding: 30rpx 0;
  text-align: center;
  border: 2rpx solid transparent;
}

.category-item.active {
  background: #FFF5F2;
  border-color: #FF6B35;
}

.category-icon {
  display: block;
  font-size: 48rpx;
  margin-bottom: 12rpx;
}

.category-name {
  display: block;
  font-size: 26rpx;
  color: #333;
}

.category-item.active .category-name {
  color: #FF6B35;
  font-weight: 500;
}

/* 商品标签 */
.tags-container {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.tag-item {
  padding: 16rpx 28rpx;
  background: #F5F5F5;
  border-radius: 30rpx;
  font-size: 26rpx;
  color: #666;
  border: 2rpx solid transparent;
}

.tag-item.active {
  background: #FFF5F2;
  border-color: #FF6B35;
  color: #FF6B35;
}

.tags-hint {
  display: block;
  font-size: 24rpx;
  color: #999;
  margin-top: 16rpx;
}

/* 自定义商品输入 */
.custom-goods-section {
  margin-top: 24rpx;
  padding-top: 24rpx;
  border-top: 1rpx solid #F0F0F0;
}

.custom-goods-label {
  display: block;
  font-size: 26rpx;
  color: #666;
  margin-bottom: 16rpx;
}

.custom-goods-input-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.custom-goods-input {
  flex: 1;
  height: 72rpx;
  background: #F8F8F8;
  border-radius: 8rpx;
  padding: 0 20rpx;
  font-size: 26rpx;
}

.custom-goods-add-btn {
  padding: 16rpx 28rpx;
  background: #FF6B35;
  color: #fff;
  border-radius: 8rpx;
  font-size: 26rpx;
  white-space: nowrap;
}

/* 时间选择网格 */
.schedule-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
}

.schedule-item {
  width: calc(25% - 15rpx);
  background: #F8F8F8;
  border-radius: 12rpx;
  padding: 24rpx 0;
  text-align: center;
  border: 2rpx solid transparent;
}

.schedule-item.active {
  background: #FFF5F2;
  border-color: #FF6B35;
}

.schedule-icon {
  display: block;
  font-size: 40rpx;
  margin-bottom: 8rpx;
}

.schedule-name {
  display: block;
  font-size: 24rpx;
  color: #666;
}

.schedule-item.active .schedule-name {
  color: #FF6B35;
  font-weight: 500;
}

/* 自定义时间段选择 */
.custom-time-section {
  margin-top: 24rpx;
  padding: 24rpx;
  background: #FFF8F5;
  border-radius: 12rpx;
  border: 2rpx solid #FFD4C7;
}

.custom-time-label {
  display: block;
  font-size: 28rpx;
  color: #FF6B35;
  margin-bottom: 20rpx;
  font-weight: 500;
}

.time-picker-row {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 20rpx;
}

.time-picker-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 20rpx 32rpx;
  background: #fff;
  border-radius: 8rpx;
  border: 2rpx solid #FF6B35;
  min-width: 180rpx;
}

.time-text {
  font-size: 28rpx;
  color: #333;
  margin-right: 12rpx;
}

.time-icon {
  font-size: 20rpx;
  color: #FF6B35;
}

.time-separator {
  font-size: 28rpx;
  color: #666;
  font-weight: 500;
}

/* 定位选择器 */
.location-selector {
  background: #F8F8F8;
  border-radius: 12rpx;
  padding: 30rpx;
  min-height: 120rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.location-empty {
  text-align: center;
}

.location-icon {
  display: block;
  font-size: 48rpx;
  margin-bottom: 12rpx;
}

.location-text {
  display: block;
  font-size: 28rpx;
  color: #333;
  margin-bottom: 8rpx;
}

.location-hint {
  display: block;
  font-size: 24rpx;
  color: #999;
}

.location-selected {
  width: 100%;
}

.location-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12rpx;
}

.location-name {
  font-size: 30rpx;
  font-weight: 500;
  color: #333;
}

.location-change {
  font-size: 26rpx;
  color: #FF6B35;
}

.location-address {
  display: block;
  font-size: 26rpx;
  color: #666;
  margin-bottom: 8rpx;
}

.location-coords {
  font-size: 22rpx;
  color: #999;
}

/* 联系方式 */
.contact-inputs .form-input {
  margin-bottom: 20rpx;
}

.contact-inputs .form-input:last-child {
  margin-bottom: 0;
}

/* 图片上传 */
.image-upload-container {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
}

.image-item {
  position: relative;
  width: 200rpx;
  height: 200rpx;
  border-radius: 12rpx;
  overflow: hidden;
  background: #F8F8F8;
}

.image-item image {
  width: 100%;
  height: 100%;
}

.delete-btn {
  position: absolute;
  top: 8rpx;
  right: 8rpx;
  width: 40rpx;
  height: 40rpx;
  background: rgba(0,0,0,0.5);
  color: #fff;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  line-height: 1;
}

.upload-btn-large {
  width: 200rpx;
  height: 200rpx;
  background: #F8F8F8;
  border-radius: 12rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  border: 2rpx dashed #DDD;
}

.upload-btn-large .icon {
  font-size: 48rpx;
  margin-bottom: 12rpx;
}

.upload-btn-large .text {
  font-size: 26rpx;
  color: #666;
  margin-bottom: 8rpx;
}

.upload-btn-large .sub-text {
  font-size: 22rpx;
  color: #999;
}

/* 文本域 */
.form-textarea {
  width: 100%;
  height: 200rpx;
  background: #F8F8F8;
  border-radius: 12rpx;
  padding: 24rpx;
  font-size: 28rpx;
  color: #333;
  box-sizing: border-box;
}

/* 合规提示 */
.compliance-notice {
  display: flex;
  align-items: flex-start;
  background: #FFF7E6;
  border-radius: 12rpx;
  padding: 20rpx;
  margin-bottom: 20rpx;
}

.notice-icon {
  font-size: 36rpx;
  margin-right: 16rpx;
  flex-shrink: 0;
}

.notice-content {
  flex: 1;
}

.notice-title {
  display: block;
  font-size: 28rpx;
  font-weight: 500;
  color: #D48806;
  margin-bottom: 6rpx;
}

.notice-text {
  display: block;
  font-size: 24rpx;
  color: #D48806;
  line-height: 1.5;
}

/* 小型合规提示 */
.compliance-notice-small {
  display: flex;
  align-items: center;
  background: #FFF7E6;
  border-radius: 8rpx;
  padding: 12rpx 16rpx;
  margin: 12rpx 0;
}

.notice-icon-small {
  font-size: 28rpx;
  margin-right: 10rpx;
}

.notice-text-small {
  font-size: 24rpx;
  color: #D48806;
}

/* 隐藏的 canvas 用于图片压缩 */
.compress-canvas {
  position: fixed;
  left: -9999px;
  top: -9999px;
  width: 800px;
  height: 800px;
}

/* 提交区域 */
.submit-section {
  padding: 0 30rpx;
  margin-top: 40rpx;
}

.submit-btn {
  background: linear-gradient(135deg, #FF6B35 0%, #FF8F50 100%);
  color: #fff;
  border-radius: 50rpx;
  height: 96rpx;
  font-size: 34rpx;
  font-weight: 500;
  border: none;
  display: flex;
  justify-content: center;
  align-items: center;
  line-height: normal;
}

.submit-btn::after {
  border: none;
}

.submit-tips {
  display: block;
  text-align: center;
  font-size: 24rpx;
  color: #999;
  margin-top: 20rpx;
}

