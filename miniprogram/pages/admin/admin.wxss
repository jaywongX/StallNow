/* 标签栏 */
.tab-bar {
  display: flex;
  background-color: #FFF;
  border-bottom: 1rpx solid #F0F0F0;
}

.tab-item {
  flex: 1;
  text-align: center;
  padding: 24rpx;
  font-size: 28rpx;
  color: #666;
  position: relative;
}

.tab-item.active {
  color: #FF6B35;
  font-weight: bold;
}

.tab-item.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 60rpx;
  height: 4rpx;
  background-color: #FF6B35;
  border-radius: 2rpx;
}

/* 状态筛选 */
.status-filter {
  display: flex;
  background-color: #FFF;
  padding: 20rpx;
  border-bottom: 1rpx solid #F0F0F0;
}

.filter-item {
  flex: 1;
  text-align: center;
  padding: 12rpx;
  margin-right: 16rpx;
  background-color: #F5F5F5;
  border-radius: 6rpx;
  font-size: 24rpx;
  color: #666;
}

.filter-item:last-child {
  margin-right: 0;
}

.filter-item.active {
  background-color: #FF6B35;
  color: #FFF;
}

/* 内容容器 */
.content-container {
  padding: 20rpx;
  min-height: calc(100vh - 200rpx);
}

/* 卡片 */
.card {
  background-color: #FFF;
  border-radius: 12rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.08);
}

.card-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 20rpx;
}

.card-header .title {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
  flex: 1;
}

.card-header .status {
  padding: 6rpx 16rpx;
  background-color: #E8F5E9;
  color: #4CAF50;
  border-radius: 6rpx;
  font-size: 22rpx;
}

.status.status-pending {
  background-color: #FFF3E0;
  color: #FF9800;
}

.card-body .row {
  display: flex;
  align-items: center;
  margin-bottom: 12rpx;
  font-size: 26rpx;
}

.card-body .row:last-child {
  margin-bottom: 0;
}

.card-body .label {
  color: #999;
  width: 160rpx;
}

.card-body .value {
  flex: 1;
  color: #333;
}

/* 反馈内容样式 */
.feedback-content {
  background-color: #f8f8f8;
  padding: 20rpx;
  border-radius: 8rpx;
  margin: 16rpx 0;
  color: #333;
  font-size: 28rpx;
  line-height: 1.6;
  word-break: break-all;
}

.card-footer {
  display: flex;
  gap: 16rpx;
  margin-top: 20rpx;
}

.card-footer .btn {
  flex: 1;
  padding: 16rpx;
  text-align: center;
  border-radius: 6rpx;
  font-size: 26rpx;
  background-color: #F5F5F5;
  color: #666;
}

.card-footer .btn.btn-secondary {
  background-color: #FFF3E0;
  color: #FF9800;
}

.card-footer .btn.btn-primary {
  background-color: #FF6B35;
  color: #FFF;
}

.card-footer .btn.btn-danger {
  background-color: #FFEBEE;
  color: #F44336;
}

/* 空状态 */
.empty {
  text-align: center;
  padding: 120rpx 0;
}

.empty image {
  width: 240rpx;
  height: 240rpx;
  margin-bottom: 30rpx;
}

/* 加载状态 */
.loading {
  text-align: center;
  padding: 80rpx 0;
  color: #999;
}

/* 申请卡片 */
.application-card {
  background-color: #FFF;
  border-radius: 12rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.08);
  overflow: hidden;
}

/* 申请人信息 */
.applicant-info {
  display: flex;
  align-items: center;
  padding: 24rpx;
  background: linear-gradient(135deg, #FF6B35 0%, #FF8C42 100%);
}

.applicant-info .avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  border: 4rpx solid rgba(255, 255, 255, 0.3);
  margin-right: 20rpx;
}

.applicant-info .info {
  flex: 1;
}

.applicant-info .nickname {
  display: block;
  font-size: 30rpx;
  color: #FFF;
  font-weight: bold;
  margin-bottom: 8rpx;
}

.applicant-info .submit-time {
  display: block;
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.8);
}

.applicant-info .status {
  padding: 8rpx 20rpx;
  background-color: rgba(255, 255, 255, 0.9);
  border-radius: 24rpx;
  font-size: 24rpx;
  color: #FF6B35;
}

/* 申请详情 */
.application-detail {
  padding: 20rpx;
}

.detail-section {
  margin-bottom: 24rpx;
  padding-bottom: 20rpx;
  border-bottom: 1rpx solid #F5F5F5;
}

.detail-section:last-child {
  margin-bottom: 0;
  padding-bottom: 0;
  border-bottom: none;
}

.section-title {
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 16rpx;
  padding-left: 16rpx;
  border-left: 8rpx solid #FF6B35;
}

.detail-row {
  display: flex;
  padding: 12rpx 0;
  font-size: 26rpx;
}

.detail-label {
  width: 160rpx;
  color: #999;
  flex-shrink: 0;
}

.detail-value {
  flex: 1;
  color: #333;
  word-break: break-all;
}

.detail-value.link {
  color: #FF6B35;
  text-decoration: underline;
}

/* 图片列表 */
.image-list {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.stall-image {
  width: 180rpx;
  height: 180rpx;
  border-radius: 8rpx;
}

/* 地图容器 */
.map-container {
  margin: 16rpx 0;
  border-radius: 12rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.1);
}

.location-map {
  width: 100%;
  height: 300rpx;
}

.detail-value.coords {
  font-family: monospace;
  font-size: 24rpx;
  color: #666;
}

/* 申请卡片底部 */
.application-card .card-footer {
  padding: 20rpx;
  background-color: #FAFAFA;
  border-top: 1rpx solid #F0F0F0;
}

