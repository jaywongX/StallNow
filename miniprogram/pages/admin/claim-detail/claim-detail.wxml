<!-- 加载中 -->
<view class="loading" wx:if="{{loading}}">
  <text>加载中...</text>
</view>

<!-- 详情内容 -->
<view class="container" wx:if="{{!loading && claim}}">
  <!-- 状态卡片 -->
  <view class="status-card status-{{claim.status}}">
    <view class="status-icon">
      <text wx:if="{{claim.status === 0}}">⏳</text>
      <text wx:if="{{claim.status === 1}}">✅</text>
      <text wx:if="{{claim.status === 2}}">❌</text>
    </view>
    <view class="status-info">
      <text class="status-text" wx:if="{{claim.status === 0}}">待审核</text>
      <text class="status-text" wx:if="{{claim.status === 1}}">已通过</text>
      <text class="status-text" wx:if="{{claim.status === 2}}">已拒绝</text>
      <text class="status-time">提交时间：{{formatTime(claim.submitTime)}}</text>
    </view>
  </view>

  <!-- 申请人信息 -->
  <view class="section">
    <view class="section-title">申请人信息</view>
    <view class="info-card">
      <view class="info-item">
        <text class="info-label">微信昵称</text>
        <view class="info-value user-info">
          <image 
            class="user-avatar" 
            src="{{claim.applicantInfo.avatarUrl || '/images/profile.png'}}" 
            mode="aspectFill"
          />
          <text>{{claim.applicantInfo.nickName || '未知用户'}}</text>
        </view>
      </view>
      <view class="info-item">
        <text class="info-label">真实姓名</text>
        <text class="info-value">{{claim.realName}}</text>
      </view>
      <view class="info-item">
        <text class="info-label">手机号码</text>
        <view class="info-value copyable" data-text="{{claim.phone}}" bindtap="onCopyContact">
          <text>{{claim.phone}}</text>
          <text class="copy-btn">复制</text>
        </view>
      </view>
      <view class="info-item" wx:if="{{claim.wechatId}}">
        <text class="info-label">微信号</text>
        <view class="info-value copyable" data-text="{{claim.wechatId}}" bindtap="onCopyContact">
          <text>{{claim.wechatId}}</text>
          <text class="copy-btn">复制</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 摊位信息 -->
  <view class="section">
    <view class="section-title">申请认领的摊位</view>
    <view class="stall-card-detail">
      <view class="stall-header">
        <text class="stall-name">{{claim.stallInfo.displayName}}</text>
      </view>
      <view class="stall-location" wx:if="{{claim.stallDetail && claim.stallDetail.location}}">
        <view class="location-info">
          <text class="icon">📍</text>
          <text class="address">{{claim.stallInfo.address || '暂无地址信息'}}</text>
        </view>
        <view class="navigate-btn" bindtap="onNavigateToStall">查看位置</view>
      </view>
      <!-- 摊位现有照片 -->
      <view class="stall-existing-photos" wx:if="{{claim.stallInfo.images && claim.stallInfo.images.length > 0}}">
        <text class="photos-label">摊位现有照片</text>
        <view class="photos-list">
          <image 
            wx:for="{{claim.stallInfo.images}}"
            wx:for-item="img"
            wx:key="*this"
            class="photo-item"
            src="{{img}}"
            mode="aspectFill"
            data-url="{{img}}"
            data-urls="{{claim.stallInfo.images}}"
            bindtap="onPreviewImage"
          />
        </view>
      </view>
    </view>
  </view>

  <!-- 证明材料 -->
  <view class="section">
    <view class="section-title">提交的证明材料</view>
    
    <!-- 摊位照片 -->
    <view class="material-section">
      <view class="material-title">
        <text>摊位实拍照片</text>
        <text class="material-count">{{claim.stallPhotos.length}}张</text>
      </view>
      <view class="material-photos">
        <image 
          wx:for="{{claim.stallPhotos}}"
          wx:for-item="photo"
          wx:key="*this"
          class="material-photo"
          src="{{photo}}"
          mode="aspectFill"
          data-url="{{photo}}"
          data-urls="{{claim.stallPhotos}}"
          bindtap="onPreviewImage"
        />
      </view>
    </view>

    <!-- 身份证照片 -->
    <view class="material-section" wx:if="{{claim.idCardPhoto}}">
      <view class="material-title">
        <text>身份证照片</text>
        <text class="optional">（选填）</text>
      </view>
      <view class="material-photos">
        <image 
          class="material-photo"
          src="{{claim.idCardPhoto}}"
          mode="aspectFill"
          data-url="{{claim.idCardPhoto}}"
          bindtap="onPreviewImage"
        />
      </view>
    </view>
  </view>

  <!-- 审核信息（已审核时显示） -->
  <view class="section" wx:if="{{claim.status !== 0}}">
    <view class="section-title">审核信息</view>
    <view class="info-card">
      <view class="info-item">
        <text class="info-label">审核结果</text>
        <text class="info-value {{claim.status === 1 ? 'pass' : 'reject'}}">
          {{claim.status === 1 ? '通过' : '拒绝'}}
        </text>
      </view>
      <view class="info-item">
        <text class="info-label">审核时间</text>
        <text class="info-value">{{formatTime(claim.auditTime)}}</text>
      </view>
      <view class="info-item" wx:if="{{claim.remark}}">
        <text class="info-label">审核备注</text>
        <text class="info-value remark">{{claim.remark}}</text>
      </view>
    </view>
  </view>

  <!-- 底部操作按钮（仅待审核时显示） -->
  <view class="footer-actions" wx:if="{{claim.status === 0}}">
    <button class="btn-reject" bindtap="onShowRejectModal">拒绝</button>
    <button class="btn-pass" bindtap="onShowPassModal">通过</button>
  </view>
</view>

<!-- 审核弹窗 -->
<view class="modal-mask" wx:if="{{showAuditModal}}" bindtap="onCloseAuditModal">
  <view class="modal-content" catchtap>
    <view class="modal-header">
      <text class="modal-title">
        {{auditAction === 'pass' ? '确认通过' : '确认拒绝'}}
      </text>
      <text class="modal-close" bindtap="onCloseAuditModal">✕</text>
    </view>
    
    <view class="modal-body">
      <view class="modal-desc" wx:if="{{auditAction === 'pass'}}">
        确认通过该认领申请？通过后申请人将成为该摊位的摊主，获得管理权限。
      </view>
      <view class="modal-desc" wx:if="{{auditAction === 'reject'}}">
        确认拒绝该认领申请？拒绝后申请人可重新提交申请。
      </view>
      
      <view class="remark-section" wx:if="{{auditAction === 'reject'}}">
        <text class="remark-label">拒绝原因 <text class="required">*</text></text>
        <textarea 
          class="remark-input"
          placeholder="请填写拒绝原因，将告知申请人"
          value="{{auditRemark}}"
          bindinput="onRemarkInput"
          maxlength="200"
        />
        <text class="remark-count">{{auditRemark.length}}/200</text>
      </view>

      <view class="remark-section optional" wx:if="{{auditAction === 'pass'}}">
        <text class="remark-label">备注（可选）</text>
        <textarea 
          class="remark-input"
          placeholder="可填写审核备注（不对外展示）"
          value="{{auditRemark}}"
          bindinput="onRemarkInput"
          maxlength="200"
        />
        <text class="remark-count">{{auditRemark.length}}/200</text>
      </view>
    </view>
    
    <view class="modal-footer">
      <button class="btn-cancel" bindtap="onCloseAuditModal">取消</button>
      <button 
        class="btn-confirm {{auditAction}}"
        bindtap="onConfirmAudit"
        loading="{{auditing}}"
        disabled="{{auditAction === 'reject' && !auditRemark.trim()}}"
      >
        {{auditAction === 'pass' ? '确认通过' : '确认拒绝'}}
      </button>
    </view>
  </view>
</view>
