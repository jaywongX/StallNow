/* 步骤指示器 */
.step-indicator {
  display: flex;
  align-items: center;
  padding: 30rpx;
  background-color: #FFF;
  margin-bottom: 20rpx;
}

.step-item {
  display: flex;
  align-items: center;
  flex: 1;
}

.step-number {
  width: 60rpx;
  height: 60rpx;
  border-radius: 50%;
  background-color: #E0E0E0;
  color: #999;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 26rpx;
  font-weight: bold;
}

.step-item.active .step-number {
  background-color: #FF6B35;
  color: #FFF;
}

.step-line {
  flex: 1;
  height: 4rpx;
  background-color: #E0E0E0;
  margin: 0 10rpx;
}

.step-item.active .step-line {
  background-color: #FF6B35;
}

/* 步骤内容 */
.step-content {
  background-color: #FFF;
  padding: 40rpx 30rpx;
  min-height: calc(100vh - 300rpx);
}

.step-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 16rpx;
}

.step-desc {
  font-size: 26rpx;
  color: #999;
  margin-bottom: 40rpx;
}

/* 表单输入 */
.picker-btn {
  padding: 24rpx;
  background-color: #F5F5F5;
  border-radius: 8rpx;
  font-size: 28rpx;
  color: #333;
}

.form-input {
  padding: 24rpx;
  background-color: #F5F5F5;
  border-radius: 8rpx;
  font-size: 28rpx;
  margin-bottom: 20rpx;
}

/* 时间类型选择 */
.time-types {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-bottom: 20rpx;
}

.time-type-item {
  padding: 16rpx 32rpx;
  background-color: #F5F5F5;
  border-radius: 32rpx;
  font-size: 28rpx;
  color: #666;
}

.time-type-item.active {
  background-color: #FF6B35;
  color: #FFF;
}

/* 位置选择器 */
.location-selector {
  display: flex;
  align-items: center;
  padding: 24rpx;
  background-color: #F5F5F5;
  border-radius: 8rpx;
  margin-bottom: 20rpx;
}

.location-selector .icon {
  font-size: 32rpx;
  margin-right: 16rpx;
}

.location-selector .text {
  flex: 1;
  font-size: 28rpx;
  color: #333;
}

/* 联系方式表单 */
.switch-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx;
  background-color: #F5F5F5;
  border-radius: 8rpx;
  margin-bottom: 20rpx;
}

.switch-row .label {
  font-size: 28rpx;
  color: #333;
}

.contact-form {
  margin-top: 30rpx;
}

.upload-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 40rpx;
  background-color: #F5F5F5;
  border-radius: 8rpx;
  margin-bottom: 20rpx;
}

.upload-btn .icon {
  font-size: 40rpx;
  margin-right: 12rpx;
}

.upload-btn .text {
  font-size: 28rpx;
  color: #666;
}

.qr-preview {
  width: 400rpx;
  height: 400rpx;
  display: block;
  margin: 20rpx auto;
  border-radius: 8rpx;
}

/* 提示 */
.tip {
  font-size: 24rpx;
  color: #FF9800;
  padding: 20rpx;
  background-color: #FFF3E0;
  border-radius: 8rpx;
  line-height: 1.6;
}

.note {
  font-size: 24rpx;
  color: #666;
  line-height: 1.8;
  padding: 20rpx;
  background-color: #F9F9F9;
  border-radius: 8rpx;
}

.note view {
  margin-bottom: 8rpx;
}

.note .example {
  margin-top: 20rpx;
  padding: 16rpx;
  background-color: #E8F5E9;
  color: #4CAF50;
  border-radius: 6rpx;
}

/* 操作按钮 */
.action-buttons {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 20rpx 30rpx;
  background-color: #FFF;
  display: flex;
  gap: 20rpx;
  box-shadow: 0 -2rpx 12rpx rgba(0, 0, 0, 0.08);
}

.action-buttons .btn {
  flex: 1;
  padding: 24rpx;
  text-align: center;
  border-radius: 8rpx;
  font-size: 30rpx;
  font-weight: bold;
}

.btn-secondary {
  background-color: #F5F5F5;
  color: #666;
}

.btn-primary {
  background-color: #FF6B35;
  color: #FFF;
}
