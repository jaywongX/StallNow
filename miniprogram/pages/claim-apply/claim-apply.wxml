<!-- 加载中 -->
<view class="loading" wx:if="{{loading}}">
  <text>加载中...</text>
</view>

<!-- 页面内容 -->
<view class="container" wx:if="{{!loading && stallInfo}}">
  <!-- 步骤指示器 -->
  <view class="step-indicator">
    <view class="step-item {{currentStep >= 1 ? 'active' : ''}}">
      <view class="step-number">1</view>
      <text class="step-text">基本信息</text>
    </view>
    <view class="step-line {{currentStep >= 2 ? 'active' : ''}}"></view>
    <view class="step-item {{currentStep >= 2 ? 'active' : ''}}">
      <view class="step-number">2</view>
      <text class="step-text">证明材料</text>
    </view>
    <view class="step-line {{currentStep >= 3 ? 'active' : ''}}"></view>
    <view class="step-item {{currentStep >= 3 ? 'active' : ''}}">
      <view class="step-number">3</view>
      <text class="step-text">确认提交</text>
    </view>
  </view>

  <!-- 摊位信息卡片 -->
  <view class="stall-card">
    <text class="stall-label">申请认领的摊位</text>
    <view class="stall-name">{{stallInfo.displayName}}</view>
    <view class="stall-address" wx:if="{{stallInfo.address}}">
      <text class="icon">📍</text>
      <text>{{stallInfo.address}}</text>
    </view>
  </view>

  <!-- Step 1: 基本信息 -->
  <view class="step-content" wx:if="{{currentStep === 1}}">
    <view class="section-title">请填写您的基本信息</view>
    
    <view class="form-group">
      <view class="form-item required">
        <text class="label">真实姓名</text>
        <input 
          class="input" 
          placeholder="请输入您的真实姓名"
          value="{{realName}}"
          bindinput="onRealNameInput"
        />
        <text class="error" wx:if="{{errors.realName}}">{{errors.realName}}</text>
      </view>

      <view class="form-item required">
        <text class="label">手机号码</text>
        <input 
          class="input" 
          type="number"
          maxlength="11"
          placeholder="请输入您的手机号码"
          value="{{phone}}"
          bindinput="onPhoneInput"
        />
        <text class="error" wx:if="{{errors.phone}}">{{errors.phone}}</text>
      </view>

      <view class="form-item">
        <text class="label">微信号（选填）</text>
        <input 
          class="input" 
          placeholder="方便管理员联系您"
          value="{{wechatId}}"
          bindinput="onWechatIdInput"
        />
      </view>
    </view>

    <view class="form-tip">
      <text class="tip-icon">💡</text>
      <text class="tip-text">信息仅用于管理员审核和后续联系，不会对外展示</text>
    </view>
  </view>

  <!-- Step 2: 证明材料 -->
  <view class="step-content" wx:if="{{currentStep === 2}}">
    <view class="section-title">请上传证明材料</view>
    
    <!-- 摊位照片 -->
    <view class="upload-section required">
      <view class="upload-title">
        <text>摊位实拍照片</text>
        <text class="upload-count">{{stallPhotos.length}}/3</text>
      </view>
      <view class="upload-desc">请上传能证明这是您摊位的照片，如摊位外观、商品陈列等（1-3张）</view>
      
      <view class="upload-grid">
        <view 
          class="upload-item" 
          wx:for="{{stallPhotos}}" 
          wx:key="*this"
        >
          <image 
            class="upload-image" 
            src="{{item}}" 
            mode="aspectFill"
            data-url="{{item}}"
            bindtap="onPreviewPhoto"
          />
          <view class="delete-btn" data-index="{{index}}" bindtap="onDeleteStallPhoto">✕</view>
        </view>
        
        <view class="upload-btn" bindtap="onUploadStallPhoto" wx:if="{{stallPhotos.length < 3}}">
          <text class="upload-icon">📷</text>
          <text class="upload-text">添加照片</text>
        </view>
      </view>
    </view>

    <!-- 身份证照片（可选） -->
    <view class="upload-section">
      <view class="upload-title">
        <text>身份证照片</text>
        <text class="optional">（选填）</text>
      </view>
      <view class="upload-desc">上传身份证可增加审核通过率，信息将严格保密</view>
      
      <view class="upload-single" wx:if="{{!idCardPhoto}}">
        <view class="upload-btn" bindtap="onUploadIdCard">
          <text class="upload-icon">🆔</text>
          <text class="upload-text">上传身份证</text>
        </view>
      </view>
      
      <view class="upload-item" wx:if="{{idCardPhoto}}">
        <image 
          class="upload-image" 
          src="{{idCardPhoto}}" 
          mode="aspectFill"
          bindtap="onPreviewPhoto"
          data-url="{{idCardPhoto}}"
        />
        <view class="delete-btn" bindtap="onDeleteIdCard">✕</view>
      </view>
    </view>
  </view>

  <!-- Step 3: 确认提交 -->
  <view class="step-content" wx:if="{{currentStep === 3}}">
    <view class="section-title">确认申请信息</view>
    
    <view class="review-section">
      <view class="review-title">基本信息</view>
      <view class="review-item">
        <text class="review-label">真实姓名</text>
        <text class="review-value">{{realName}}</text>
      </view>
      <view class="review-item">
        <text class="review-label">手机号码</text>
        <text class="review-value">{{phone}}</text>
      </view>
      <view class="review-item" wx:if="{{wechatId}}">
        <text class="review-label">微信号</text>
        <text class="review-value">{{wechatId}}</text>
      </view>
    </view>

    <view class="review-section">
      <view class="review-title">摊位照片（{{stallPhotos.length}}张）</view>
      <view class="review-images">
        <image 
          wx:for="{{stallPhotos}}" 
          wx:key="*this"
          class="review-image" 
          src="{{item}}" 
          mode="aspectFill"
        />
      </view>
    </view>

    <view class="review-section" wx:if="{{idCardPhoto}}">
      <view class="review-title">身份证照片</view>
      <view class="review-images">
        <image class="review-image" src="{{idCardPhoto}}" mode="aspectFill"/>
      </view>
    </view>

    <!-- 协议勾选 -->
    <view class="agreement-section">
      <checkbox-group bindchange="onAgreementChange">
        <label class="checkbox-label">
          <checkbox value="agreed" checked="{{agreementChecked}}"/>
          <text class="agreement-text">我确认以上信息真实有效，如有虚假愿意承担相应责任</text>
        </label>
      </checkbox-group>
    </view>
  </view>

  <!-- 底部按钮 -->
  <view class="footer-btns">
    <button 
      class="btn-prev" 
      bindtap="onPrevStep" 
      wx:if="{{currentStep > 1}}"
    >上一步</button>
    
    <button 
      class="btn-next {{currentStep === 1 && (!realName || !phone) ? 'disabled' : ''}} {{currentStep === 2 && stallPhotos.length === 0 ? 'disabled' : ''}}"
      bindtap="onNextStep"
      wx:if="{{currentStep < 3}}"
    >下一步</button>
    
    <button 
      class="btn-submit {{!agreementChecked || submitting ? 'disabled' : ''}}"
      bindtap="onSubmit"
      loading="{{submitting}}"
      wx:if="{{currentStep === 3}}"
    >提交申请</button>
  </view>
</view>
