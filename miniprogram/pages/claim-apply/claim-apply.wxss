.container {
  padding: 20rpx 30rpx 160rpx;
  background: #f5f5f5;
  min-height: 100vh;
}

/* 步骤指示器 */
.step-indicator {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 30rpx 20rpx;
  background: #fff;
  border-radius: 16rpx;
  margin-bottom: 20rpx;
}

.step-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.step-number {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  background: #e0e0e0;
  color: #999;
  font-size: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-weight: bold;
}

.step-item.active .step-number {
  background: #FF6B35;
  color: #fff;
}

.step-text {
  font-size: 22rpx;
  color: #999;
  margin-top: 8rpx;
}

.step-item.active .step-text {
  color: #FF6B35;
}

.step-line {
  width: 80rpx;
  height: 2rpx;
  background: #e0e0e0;
  margin: 0 20rpx;
  margin-bottom: 30rpx;
}

.step-line.active {
  background: #FF6B35;
}

/* 摊位卡片 */
.stall-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
}

.stall-label {
  font-size: 24rpx;
  color: #999;
  margin-bottom: 12rpx;
  display: block;
}

.stall-name {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 12rpx;
}

.stall-address {
  font-size: 26rpx;
  color: #666;
  display: flex;
  align-items: center;
}

.stall-address .icon {
  margin-right: 8rpx;
}

/* 步骤内容 */
.step-content {
  background: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 30rpx;
}

/* 表单 */
.form-group {
  margin-bottom: 20rpx;
}

.form-item {
  margin-bottom: 30rpx;
}

.form-item.required .label::before {
  content: '*';
  color: #F44336;
  margin-right: 8rpx;
}

.label {
  font-size: 28rpx;
  color: #333;
  margin-bottom: 12rpx;
  display: block;
}

.input {
  height: 88rpx;
  background: #f8f8f8;
  border-radius: 12rpx;
  padding: 0 24rpx;
  font-size: 28rpx;
  color: #333;
}

.error {
  font-size: 24rpx;
  color: #F44336;
  margin-top: 8rpx;
  display: block;
}

.form-tip {
  display: flex;
  align-items: flex-start;
  background: #FFF7E6;
  padding: 20rpx;
  border-radius: 12rpx;
}

.tip-icon {
  margin-right: 12rpx;
  font-size: 28rpx;
}

.tip-text {
  font-size: 24rpx;
  color: #FF9500;
  flex: 1;
  line-height: 1.5;
}

/* 上传区域 */
.upload-section {
  margin-bottom: 40rpx;
}

.upload-section.required .upload-title::before {
  content: '*';
  color: #F44336;
  margin-right: 8rpx;
}

.upload-title {
  font-size: 28rpx;
  color: #333;
  margin-bottom: 12rpx;
  display: flex;
  align-items: center;
}

.upload-count {
  font-size: 24rpx;
  color: #999;
  margin-left: 16rpx;
}

.optional {
  font-size: 24rpx;
  color: #999;
  font-weight: normal;
  margin-left: 8rpx;
}

.upload-desc {
  font-size: 24rpx;
  color: #999;
  margin-bottom: 20rpx;
}

.upload-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
}

.upload-item {
  width: 200rpx;
  height: 200rpx;
  position: relative;
}

.upload-image {
  width: 100%;
  height: 100%;
  border-radius: 12rpx;
}

.delete-btn {
  position: absolute;
  top: -10rpx;
  right: -10rpx;
  width: 40rpx;
  height: 40rpx;
  background: #F44336;
  color: #fff;
  border-radius: 50%;
  font-size: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.upload-btn {
  width: 200rpx;
  height: 200rpx;
  background: #f8f8f8;
  border-radius: 12rpx;
  border: 2rpx dashed #ddd;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.upload-icon {
  font-size: 48rpx;
  margin-bottom: 12rpx;
}

.upload-text {
  font-size: 24rpx;
  color: #999;
}

/* 确认页 */
.review-section {
  margin-bottom: 30rpx;
  padding-bottom: 30rpx;
  border-bottom: 2rpx solid #f0f0f0;
}

.review-section:last-child {
  border-bottom: none;
}

.review-title {
  font-size: 28rpx;
  color: #333;
  font-weight: bold;
  margin-bottom: 20rpx;
}

.review-item {
  display: flex;
  margin-bottom: 16rpx;
}

.review-label {
  font-size: 26rpx;
  color: #666;
  width: 160rpx;
}

.review-value {
  font-size: 26rpx;
  color: #333;
  flex: 1;
}

.review-images {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.review-image {
  width: 160rpx;
  height: 160rpx;
  border-radius: 12rpx;
}

/* 协议 */
.agreement-section {
  margin-top: 40rpx;
  padding: 20rpx;
  background: #f8f8f8;
  border-radius: 12rpx;
}

.checkbox-label {
  display: flex;
  align-items: flex-start;
}

.agreement-text {
  font-size: 24rpx;
  color: #666;
  margin-left: 12rpx;
  line-height: 1.5;
  flex: 1;
}

/* 底部按钮 */
.footer-btns {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 20rpx 30rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  background: #fff;
  display: flex;
  gap: 20rpx;
  box-shadow: 0 -4rpx 20rpx rgba(0,0,0,0.05);
}

.btn-prev {
  flex: 1;
  height: 88rpx;
  background: #f0f0f0;
  color: #666;
  font-size: 30rpx;
  border-radius: 44rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border: none;
}

.btn-next, .btn-submit {
  flex: 2;
  height: 88rpx;
  background: #FF6B35;
  color: #fff;
  font-size: 30rpx;
  border-radius: 44rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border: none;
}

.btn-next.disabled, .btn-submit.disabled {
  background: #ccc;
}

.btn-prev::after, .btn-next::after, .btn-submit::after {
  border: none;
}

/* 加载中 */
.loading {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 100rpx;
  font-size: 28rpx;
  color: #999;
}
