<!-- 加载中 -->
<view class="loading" wx:if="{{loading}}">
  <text>加载中...</text>
</view>

<!-- 详情内容 -->
<view class="detail-container" wx:if="{{stall}}">
  <!-- 摊位状态提示 -->
  <view class="stall-status-banner" wx:if="{{!isStallActive}}">
    <text class="status-icon">⚠️</text>
    <text class="status-text">{{stallStatusText}}</text>
    <text class="status-desc">该摊主可能暂时休息或已停止经营</text>
  </view>
  
  <!-- 图片轮播 -->
  <swiper
    class="image-swiper"
    indicator-dots
    autoplay
    interval="3000"
    duration="300"
    wx:if="{{stall.images && stall.images.length > 0}}"
  >
    <swiper-item wx:for="{{stall.images}}" wx:key="*this">
      <image
        class="swiper-image"
        src="{{item}}"
        mode="aspectFill"
        data-src="{{item}}"
        bindtap="onPreviewImage"
      />
    </swiper-item>
  </swiper>

  <!-- 无图片占位 -->
  <view class="no-image" wx:if="{{!stall.images || stall.images.length === 0}}">
    <text>暂无图片</text>
  </view>

  <!-- 基本信息 -->
  <view class="info-section">
    <!-- 展示名 -->
    <view class="display-name">{{stall.displayName}}</view>

    <!-- 商家名称（可选） -->
    <view class="vendor-name" wx:if="{{stall.vendorName}}">{{stall.vendorName}}</view>

    <!-- 可信度标识 -->
    <reliability-badge
      reliability="{{stall.reliability}}"
      expanded="{{false}}"
    />

    <!-- 商品标签 -->
    <view class="info-row goods-row" wx:if="{{stall.goodsTags && stall.goodsTags.length > 0}}">
      <text class="icon">📦</text>
      <text class="label">商品：</text>
      <view class="goods-tags">
        <text class="goods-tag" wx:for="{{stall.goodsTags}}" wx:key="*this">{{item}}</text>
      </view>
    </view>

    <!-- 位置信息 -->
    <view class="info-row">
      <text class="icon">📍</text>
      <text class="label">地址：</text>
      <text class="text">{{stall.address || '暂无'}}</text>
    </view>

    <!-- 外观特征 -->
    <view class="info-row" wx:if="{{stall.landmark}}">
      <text class="icon">🏪</text>
      <text class="label">外观：</text>
      <text class="text">{{stall.landmark}}</text>
    </view>

    <!-- 出摊时间 -->
    <view class="info-row">
      <text class="icon">🕐</text>
      <text class="label">时间：</text>
      <text class="text">{{scheduleDisplay}}</text>
    </view>

    <!-- 导航按钮 -->
    <view class="navigate-btn" bindtap="onNavigate">
      🧭 一键导航
    </view>
  </view>

  <!-- 联系方式区 -->
  <view class="contact-section">
    <view class="section-title">联系方式</view>

    <!-- 默认状态 -->
    <view class="contact-default" wx:if="{{!showContact}}">
      <text class="icon">📍</text>
      <text class="text">现场经营，建议到现场寻找</text>
      <view class="show-contact-btn" bindtap="onShowContact">
        联系摊主
      </view>
    </view>

    <!-- 展示状态 -->
    <view class="contact-info" wx:if="{{showContact}}">
      <!-- 电话 -->
      <view class="contact-item" wx:if="{{stall.contact && stall.contact.phone}}">
        <text class="label">📞 电话</text>
        <text class="value">{{stall.contact.phone}}</text>
        <text
          class="copy-btn"
          data-text="{{stall.contact.phone}}"
          bindtap="onCopyContact"
        >复制</text>
      </view>

      <!-- 微信二维码 -->
      <view class="contact-item" wx:if="{{stall.contact && stall.contact.wechatQR}}">
        <text class="label">💬 微信</text>
        <text class="desc">添加微信前请简单说明来意</text>
        <image
          class="qr-code"
          src="{{stall.contact.wechatQR}}"
          mode="aspectFit"
          data-url="{{stall.contact.wechatQR}}"
          bindtap="onPreviewQRCode"
        />
      </view>

      <!-- 无联系方式 -->
      <view class="no-contact" wx:if="{{!stall.contact || (!stall.contact.phone && !stall.contact.wechatQR)}}">
        <text class="icon">ℹ️</text>
        <text class="text">暂无线上联系方式，建议在常见时间到现场寻找</text>
      </view>
    </view>
  </view>

  <!-- 认领状态展示区 -->
  <!-- 情况1：待认领 -->
  <view class="claim-section claim-unclaimed" wx:if="{{stall.claimStatus === 'unclaimed' && stall.createdBy === 'admin_proxy' && (!claimStatus || claimStatus.canApply)}}">
    <view class="claim-info">
      <text class="claim-icon">🏷️</text>
      <view class="claim-text">
        <text class="claim-title">营业中（待认领）</text>
        <text class="claim-desc">这是管理员代录入的摊位，如果你是摊主可以认领</text>
      </view>
    </view>
    <view class="claim-btn" bindtap="onClaimStall">
      认领摊位
    </view>
  </view>

  <!-- 情况2：审核中 -->
  <view class="claim-section claim-pending" wx:if="{{claimStatus && claimStatus.myClaim && claimStatus.myClaim.status === 0}}">
    <view class="claim-info">
      <text class="claim-icon">⏳</text>
      <view class="claim-text">
        <text class="claim-title">认领申请审核中</text>
        <text class="claim-desc">您提交的认领申请正在审核，请耐心等待</text>
      </view>
    </view>
  </view>

  <!-- 情况3：审核通过（已是摊主）或摊主自己创建的摊位 -->
  <view class="claim-section claim-claimed" wx:if="{{claimStatus && claimStatus.isOwner}}">
    <view class="claim-info">
      <text class="claim-icon">✅</text>
      <view class="claim-text">
        <text class="claim-title">您是该摊位的摊主</text>
        <text class="claim-desc" wx:if="{{claimStatus.isCreator}}">这是您自己创建的摊位</text>
        <text class="claim-desc" wx:else>您已通过审核，可以管理这个摊位</text>
      </view>
    </view>
    <view class="claim-btn manage" bindtap="onManageStall">
      管理摊位
    </view>
  </view>

  <!-- 情况4：审核拒绝 -->
  <view class="claim-section claim-rejected" wx:if="{{claimStatus && claimStatus.myClaim && claimStatus.myClaim.status === 2}}">
    <view class="claim-info">
      <text class="claim-icon">❌</text>
      <view class="claim-text">
        <text class="claim-title">认领申请未通过</text>
        <text class="claim-desc" wx:if="{{claimStatus.myClaim.remark}}">原因：{{claimStatus.myClaim.remark}}</text>
        <text class="claim-desc" wx:else>您的认领申请未通过审核</text>
      </view>
    </view>
    <view class="claim-btn" bindtap="onReapplyClaim">
      重新申请
    </view>
  </view>

  <!-- 摊主/管理员操作区 -->
  <view class="owner-section" wx:if="{{isAdmin || (stall.claimStatus === 'claimed' && stall.isOwner)}}">
    <view class="owner-btn danger" bindtap="onOfflineStall">
      一键下线
    </view>
  </view>

  <!-- 反馈区 -->
  <view class="feedback-section">
    <view class="feedback-header">
      <text class="text">摊位为流动经营，信息可能变化，仅供参考</text>
      <view class="feedback-btn" bindtap="onShowFeedback">
        信息有变化？
      </view>
    </view>

    <!-- 反馈选项 -->
    <view class="feedback-options" wx:if="{{showFeedbackModal}}">
      <view class="feedback-option" data-type="wrong_location" bindtap="onSubmitFeedback">
        📍 位置不对
      </view>
      <view class="feedback-option" data-type="wrong_info" bindtap="onSubmitFeedback">
        📦 商品变化
      </view>
      <view class="feedback-option" data-type="not_exist" bindtap="onSubmitFeedback">
        ❌ 已不出摊
      </view>
      <view class="feedback-option cancel" bindtap="onCancelFeedback">
        取消
      </view>
    </view>
  </view>

  <!-- 现场提示 -->
  <view class="tips-section">
    <text class="tips-icon">⚠️</text>
    <text class="tips-text">以现场实际为准</text>
  </view>

  <!-- 合规声明 -->
  <view class="disclaimer">
    信息展示，不构成交易建议
  </view>
</view>

  <!-- 联系方式确认弹窗 -->
<view class="modal-mask" wx:if="{{showContactModal}}" bindtap="onCancelContact">
  <view class="modal-content contact-modal" catchtap>
    <view class="modal-header">
      <text class="title">联系提示</text>
      <text class="close" bindtap="onCancelContact">✕</text>
    </view>
    <view class="modal-body">
      <text class="text">联系方式由摊主自行提供，仅用于提前确认出摊情况。</text>
      <text class="text">商品与实际情况以现场为准。</text>
    </view>
    <view class="modal-footer">
      <view class="btn cancel" bindtap="onCancelContact">取消</view>
      <view class="btn confirm" bindtap="onConfirmContact">继续查看</view>
    </view>
  </view>
</view>

<!-- 收藏引导轻提示 -->
<view wx:if="{{showFavoriteGuide}}" class="favorite-guide" animation="{{favoriteGuideAnimation}}">
  <view class="guide-content">
    <view class="guide-star">⭐</view>
    <view class="guide-text">
      <text class="guide-title">收藏这个摊位</text>
      <text class="guide-desc">下次更容易找到</text>
    </view>
    <view class="guide-actions">
      <button class="btn-favorite" bindtap="onFavoriteStall">收藏</button>
      <button class="btn-later" bindtap="onCloseFavoriteGuide">先看看</button>
    </view>
  </view>
  <view class="guide-close" bindtap="onCloseFavoriteGuide">✕</view>
</view>
