/* 加载中 */
.loading {
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 100vh;
  color: #999;
}

/* 图片轮播 */
.image-swiper {
  width: 100%;
  height: 500rpx;
  background-color: #F5F5F5;
}

.swiper-image {
  width: 100%;
  height: 100%;
}

/* 无图片 */
.no-image {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 500rpx;
  background-color: #F5F5F5;
  color: #999;
}

/* 摊位状态提示横幅 */
.stall-status-banner {
  background: linear-gradient(135deg, #FFEBEE 0%, #FCE4EC 100%);
  padding: 30rpx;
  margin: 20rpx;
  border-radius: 16rpx;
  border-left: 8rpx solid #F44336;
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
}

.stall-status-banner .status-icon {
  font-size: 48rpx;
  margin-bottom: 12rpx;
}

.stall-status-banner .status-text {
  font-size: 32rpx;
  font-weight: bold;
  color: #D32F2F;
  margin-bottom: 8rpx;
}

.stall-status-banner .status-desc {
  font-size: 26rpx;
  color: #666;
}

/* 信息区 */
.info-section {
  background-color: #FFF;
  padding: 30rpx;
  margin-bottom: 20rpx;
}

.display-name {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 12rpx;
}

.vendor-name {
  font-size: 28rpx;
  color: #666;
  margin-bottom: 20rpx;
}

.info-row {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
  font-size: 28rpx;
  color: #666;
}

.info-row .icon {
  font-size: 32rpx;
  margin-right: 12rpx;
}

.info-row .text {
  flex: 1;
}

.info-row .note {
  color: #999;
  margin-left: 20rpx;
  font-size: 24rpx;
}

/* 商品标签行 */
.info-row.goods-row {
  align-items: flex-start;
}

.goods-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  flex: 1;
}

.goods-tag {
  font-size: 26rpx;
  color: #FF6B35;
  background: #FFF3E0;
  padding: 6rpx 16rpx;
  border-radius: 8rpx;
  white-space: nowrap;
}

/* 操作按钮组 */
.action-btns {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  margin-top: 20rpx;
}

.navigate-btn {
  background-color: #FFF3E0;
  color: #FF6B35;
  text-align: center;
  padding: 28rpx;
  border-radius: 12rpx;
  font-size: 32rpx;
  font-weight: bold;
}

/* 操作按钮行 */
.action-row {
  display: flex;
  gap: 16rpx;
}

.like-btn {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  background: linear-gradient(135deg, #FFF0F0 0%, #FFF5F5 100%);
  color: #FF4D4F;
  text-align: center;
  padding: 24rpx;
  border-radius: 12rpx;
  font-size: 28rpx;
  font-weight: 600;
  border: 2rpx solid #FFCCC7;
}

.like-btn.liked {
  background: linear-gradient(135deg, #FF4D4F 0%, #FF7875 100%);
  color: #FFF;
  border-color: #FF4D4F;
}

.btn-icon {
  font-size: 32rpx;
}

.btn-text {
  font-size: 28rpx;
}

.btn-count {
  background: rgba(255, 255, 255, 0.2);
  padding: 2rpx 12rpx;
  border-radius: 20rpx;
  font-size: 24rpx;
}

.favorite-btn {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  background: linear-gradient(135deg, #FFF9E6 0%, #FFFBF0 100%);
  color: #FFB800;
  text-align: center;
  padding: 24rpx;
  border-radius: 12rpx;
  font-size: 28rpx;
  font-weight: 600;
  border: 2rpx solid #FFE082;
}

.favorite-btn.favorited {
  background: linear-gradient(135deg, #FFB800 0%, #FFC107 100%);
  color: #FFF;
  border-color: #FFB800;
}

/* 价格文本 */
.price-text {
  color: #FF6B35;
  font-weight: 500;
}

/* 联系方式区 */
.contact-section {
  background-color: #FFF;
  padding: 30rpx;
  margin-bottom: 20rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 20rpx;
}

.contact-default {
  text-align: center;
  padding: 40rpx 0;
}

.contact-default .icon {
  display: block;
  font-size: 64rpx;
  margin-bottom: 16rpx;
}

.contact-default .text {
  display: block;
  color: #666;
  margin-bottom: 30rpx;
}

.show-contact-btn {
  display: inline-block;
  background-color: #FF6B35;
  color: #FFF;
  padding: 16rpx 48rpx;
  border-radius: 8rpx;
  font-size: 28rpx;
}

.contact-info .contact-item {
  display: flex;
  flex-wrap: wrap;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #F0F0F0;
}

.contact-item:last-child {
  border-bottom: none;
}

.contact-item .label {
  display: block;
  width: 100%;
  font-size: 28rpx;
  color: #333;
  margin-bottom: 12rpx;
}

.contact-item .desc {
  display: block;
  width: 100%;
  font-size: 24rpx;
  color: #999;
  margin-bottom: 16rpx;
}

.contact-item .value {
  flex: 1;
  font-size: 28rpx;
  color: #666;
}

.contact-item .copy-btn {
  padding: 8rpx 16rpx;
  background-color: #F5F5F5;
  border-radius: 6rpx;
  font-size: 24rpx;
  color: #666;
}

.qr-code {
  width: 400rpx;
  height: 400rpx;
  display: block;
  margin: 20rpx auto;
}

.no-contact {
  display: flex;
  align-items: center;
  padding: 20rpx;
  background-color: #F9F9F9;
  border-radius: 8rpx;
}

.no-contact .icon {
  font-size: 40rpx;
  margin-right: 16rpx;
}

.no-contact .text {
  flex: 1;
  color: #666;
  font-size: 26rpx;
}

/* 认领提示区 */
.claim-section {
  margin: 20rpx;
  padding: 30rpx;
  border-radius: 20rpx;
  border: 2rpx solid;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.1);
}

/* 待认领状态 */
.claim-section.claim-unclaimed {
  background: linear-gradient(135deg, #E3F2FD 0%, #E8F5E9 100%);
  border-color: rgba(25, 118, 210, 0.2);
}

.claim-section.claim-unclaimed .claim-title {
  color: #1976D2;
}

.claim-section.claim-unclaimed .claim-desc {
  color: #555;
}

.claim-section.claim-unclaimed .claim-btn {
  background: linear-gradient(135deg, #1976D2 0%, #2196F3 100%);
}

/* 审核中状态 */
.claim-section.claim-pending {
  background: linear-gradient(135deg, #FFF7E6 0%, #FFF5E0 100%);
  border-color: rgba(255, 149, 0, 0.2);
}

.claim-section.claim-pending .claim-title {
  color: #FF9500;
}

.claim-section.claim-pending .claim-desc {
  color: #666;
}

/* 已通过状态 */
.claim-section.claim-claimed {
  background: linear-gradient(135deg, #E8F5E9 0%, #F1F8E9 100%);
  border-color: rgba(76, 175, 80, 0.2);
}

.claim-section.claim-claimed .claim-title {
  color: #2E7D32;
}

.claim-section.claim-claimed .claim-desc {
  color: #558B2F;
}

.claim-section.claim-claimed .claim-btn {
  background: linear-gradient(135deg, #4CAF50 0%, #66BB6A 100%);
}

/* 已拒绝状态 */
.claim-section.claim-rejected {
  background: linear-gradient(135deg, #FFF1F0 0%, #FFF0F0 100%);
  border-color: rgba(245, 34, 45, 0.2);
}

.claim-section.claim-rejected .claim-title {
  color: #F5222D;
}

.claim-section.claim-rejected .claim-desc {
  color: #666;
}

.claim-section.claim-rejected .claim-btn {
  background: linear-gradient(135deg, #F5222D 0%, #FF4D4F 100%);
}

.claim-info {
  display: flex;
  align-items: flex-start;
  margin-bottom: 24rpx;
}

.claim-icon {
  font-size: 48rpx;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.claim-text {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.claim-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #2E7D32;
  margin-bottom: 8rpx;
}

.claim-desc {
  font-size: 26rpx;
  color: #558B2F;
  line-height: 1.5;
}

.claim-btn {
  background: linear-gradient(135deg, #4CAF50 0%, #66BB6A 100%);
  color: #FFF;
  text-align: center;
  padding: 24rpx;
  border-radius: 12rpx;
  font-size: 30rpx;
  font-weight: 600;
  box-shadow: 0 4rpx 16rpx rgba(76, 175, 80, 0.3);
  transition: transform 0.2s;
}

.claim-btn:active {
  transform: scale(0.98);
}

/* 摊主操作区 */
.owner-section {
  background-color: #FFF;
  padding: 30rpx;
  margin-bottom: 20rpx;
}

.owner-btn {
  background-color: #FFF3E0;
  color: #FF6B35;
  text-align: center;
  padding: 24rpx;
  border-radius: 8rpx;
  font-size: 30rpx;
  margin-bottom: 16rpx;
}

.owner-btn.danger {
  background-color: #FFEBEE;
  color: #F44336;
}

/* 反馈区 */
.feedback-section {
  background-color: #FFF;
  padding: 30rpx;
  margin-bottom: 20rpx;
}

.feedback-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.feedback-header .text {
  flex: 1;
  font-size: 26rpx;
  color: #999;
}

.feedback-btn {
  padding: 12rpx 24rpx;
  background-color: #F5F5F5;
  border-radius: 6rpx;
  font-size: 24rpx;
  color: #666;
}

.feedback-options {
  margin-top: 20rpx;
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 16rpx;
}

.feedback-option {
  padding: 24rpx;
  background-color: #F5F5F5;
  border-radius: 8rpx;
  text-align: center;
  font-size: 28rpx;
  color: #333;
}

.feedback-option.cancel {
  grid-column: 1 / -1;
  background-color: #FFF;
  color: #999;
}

/* 现场提示 */
.tips-section {
  background-color: #FFF9E6;
  padding: 24rpx;
  margin-bottom: 20rpx;
  display: flex;
  align-items: center;
}

.tips-icon {
  font-size: 32rpx;
  margin-right: 12rpx;
}

.tips-text {
  flex: 1;
  font-size: 26rpx;
  color: #FF9800;
  font-weight: bold;
}

/* 合规声明 */
.disclaimer {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background-color: #FFF;
  padding: 20rpx;
  text-align: center;
  font-size: 24rpx;
  color: #999;
  border-top: 1rpx solid #F0F0F0;
}

/* 弹窗 */
.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.5);
  z-index: 1000;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 40rpx;
}

.modal-content {
  background-color: #FFF;
  border-radius: 16rpx;
  width: 100%;
  max-width: 600rpx;
  overflow: hidden;
}

.modal-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 30rpx;
  border-bottom: 1rpx solid #F0F0F0;
}

.modal-header .title {
  font-size: 32rpx;
  font-weight: bold;
}

.modal-header .close {
  font-size: 40rpx;
  color: #999;
}

.modal-body {
  padding: 30rpx;
}

.modal-body .text {
  display: block;
  font-size: 28rpx;
  color: #333;
  margin-bottom: 16rpx;
  line-height: 1.6;
}

.modal-footer {
  display: flex;
  border-top: 1rpx solid #F0F0F0;
}

.modal-footer .btn {
  flex: 1;
  padding: 30rpx;
  text-align: center;
  font-size: 28rpx;
  border-right: 1rpx solid #F0F0F0;
}

.modal-footer .btn:last-child {
  border-right: none;
}

.modal-footer .btn.cancel {
  color: #666;
}

.modal-footer .btn.confirm {
  color: #FF6B35;
  font-weight: bold;
}

.contact-modal .modal-body {
  background-color: #FFF9E6;
  padding: 40rpx 30rpx;
}

/* 收藏引导弹窗 */
.favorite-guide-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.4);
  z-index: 999;
  display: flex;
  align-items: center;
  justify-content: center;
}

.favorite-guide {
  width: 560rpx;
  background: #FFF;
  border-radius: 24rpx;
  padding: 48rpx 40rpx 40rpx;
  text-align: center;
  box-shadow: 0 16rpx 48rpx rgba(0, 0, 0, 0.15);
  animation: guideScaleIn 0.3s ease;
}

@keyframes guideScaleIn {
  from {
    opacity: 0;
    transform: scale(0.9);
  }
  to {
    opacity: 1;
    transform: scale(1);
  }
}

.favorite-guide .guide-star {
  font-size: 80rpx;
  margin-bottom: 20rpx;
  animation: starPulse 1.5s ease infinite;
}

@keyframes starPulse {
  0%, 100% { transform: scale(1); }
  50% { transform: scale(1.1); }
}

.favorite-guide .guide-title {
  font-size: 36rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 12rpx;
}

.favorite-guide .guide-desc {
  font-size: 28rpx;
  color: #999;
  margin-bottom: 40rpx;
}

.favorite-guide .guide-actions {
  display: flex;
  gap: 24rpx;
  justify-content: center;
}

.favorite-guide .btn-favorite {
  flex: 1;
  padding: 24rpx 0;
  background: linear-gradient(135deg, #FF6B35 0%, #FF8A5C 100%);
  color: #fff;
  font-size: 30rpx;
  font-weight: 500;
  border-radius: 44rpx;
  border: none;
  line-height: 1.4;
}

.favorite-guide .btn-later {
  flex: 1;
  padding: 24rpx 0;
  background: #F5F5F5;
  color: #666;
  font-size: 30rpx;
  border-radius: 44rpx;
  border: none;
  line-height: 1.4;
}


