.container {
  min-height: 100vh;
  background: #f5f5f5;
  padding: 20rpx;
  box-sizing: border-box;
}

/* 加载中 */
.loading {
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 100rpx 0;
  color: #999;
}

/* 空状态 */
.empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 150rpx 40rpx;
}

.empty-icon {
  font-size: 120rpx;
  margin-bottom: 30rpx;
}

.empty-text {
  font-size: 32rpx;
  color: #333;
  margin-bottom: 16rpx;
}

.empty-tip {
  font-size: 26rpx;
  color: #999;
  margin-bottom: 40rpx;
}

.empty-btn {
  padding: 20rpx 60rpx;
  background: linear-gradient(135deg, #FF6B35, #FF8C42);
  color: #fff;
  font-size: 28rpx;
  border-radius: 40rpx;
}

/* 收藏列表 */
.favorites-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

/* 摊位卡片 */
.stall-card {
  background: #fff;
  border-radius: 16rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
}

/* 摊位图片 */
.stall-image {
  position: relative;
  width: 100%;
  height: 300rpx;
}

.stall-image image {
  width: 100%;
  height: 100%;
}

.stall-image .no-image {
  width: 100%;
  height: 100%;
  display: flex;
  justify-content: center;
  align-items: center;
  background: #f0f0f0;
  color: #999;
}

/* 状态标签 */
.status-tag {
  position: absolute;
  top: 16rpx;
  left: 16rpx;
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
  font-size: 22rpx;
  color: #fff;
}

.status-tag.active {
  background: rgba(76, 175, 80, 0.9);
}

.status-tag.inactive {
  background: rgba(158, 158, 158, 0.9);
}

/* 摊位信息 */
.stall-info {
  padding: 24rpx;
}

.stall-name {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 16rpx;
}

/* 商品标签 */
.goods-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-bottom: 16rpx;
}

.goods-tag {
  padding: 6rpx 16rpx;
  background: #FFF5F0;
  color: #FF6B35;
  font-size: 22rpx;
  border-radius: 20rpx;
}

/* 地址和时间 */
.stall-address,
.stall-time {
  display: flex;
  align-items: center;
  font-size: 26rpx;
  color: #666;
  margin-bottom: 8rpx;
}

.stall-address .icon,
.stall-time .icon {
  margin-right: 8rpx;
}

.stall-address .text,
.stall-time .text {
  flex: 1;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

/* 操作区 */
.stall-actions {
  display: flex;
  border-top: 1rpx solid #f0f0f0;
}

.action-btn {
  flex: 1;
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 24rpx 0;
  font-size: 26rpx;
  color: #666;
}

.action-btn .icon {
  margin-right: 8rpx;
}

.action-btn.navigate {
  color: #FF6B35;
  border-right: 1rpx solid #f0f0f0;
}

.action-btn.remove {
  color: #999;
}

/* 加载更多 */
.load-more,
.no-more {
  text-align: center;
  padding: 30rpx 0;
  color: #999;
  font-size: 26rpx;
}
