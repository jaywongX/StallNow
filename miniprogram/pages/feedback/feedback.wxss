/* 意见反馈页面样式 */

.container {
  min-height: 100vh;
  background: #F5F5F5;
  padding-bottom: 60rpx;
}

/* 页面头部 */
.page-header {
  background: linear-gradient(135deg, #FF6B35 0%, #FF8F50 100%);
  padding: 60rpx 30rpx;
  text-align: center;
}

.header-title {
  display: block;
  font-size: 40rpx;
  font-weight: bold;
  color: #fff;
  margin-bottom: 12rpx;
}

.header-subtitle {
  display: block;
  font-size: 26rpx;
  color: rgba(255,255,255,0.8);
}

/* 表单区域 */
.form-section {
  padding: 30rpx;
}

.form-group {
  background: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 24rpx;
}

.group-header {
  display: flex;
  align-items: center;
  margin-bottom: 24rpx;
}

.group-title {
  font-size: 32rpx;
  font-weight: 500;
  color: #333;
}

.required {
  color: #FF6B35;
  margin-left: 8rpx;
  font-size: 28rpx;
}

.optional {
  color: #999;
  margin-left: 8rpx;
  font-size: 24rpx;
}

/* 反馈类型网格 */
.type-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
}

.type-item {
  width: calc(50% - 10rpx);
  background: #F8F8F8;
  border-radius: 12rpx;
  padding: 24rpx 0;
  text-align: center;
  border: 2rpx solid transparent;
  transition: all 0.3s;
}

.type-item.active {
  background: #FFF5F2;
  border-color: #FF6B35;
}

.type-icon {
  display: block;
  font-size: 40rpx;
  margin-bottom: 8rpx;
}

.type-name {
  display: block;
  font-size: 26rpx;
  color: #333;
}

.type-item.active .type-name {
  color: #FF6B35;
  font-weight: 500;
}

/* 文本域 */
.content-textarea {
  width: 100%;
  min-height: 240rpx;
  background: #F8F8F8;
  border-radius: 12rpx;
  padding: 24rpx;
  font-size: 28rpx;
  color: #333;
  box-sizing: border-box;
}

.char-count {
  display: block;
  text-align: right;
  font-size: 24rpx;
  color: #999;
  margin-top: 12rpx;
}

/* 表单输入 */
.form-input {
  width: 100%;
  height: 88rpx;
  background: #F8F8F8;
  border-radius: 12rpx;
  padding: 0 24rpx;
  font-size: 28rpx;
  color: #333;
  box-sizing: border-box;
}

.input-hint {
  display: block;
  font-size: 24rpx;
  color: #999;
  margin-top: 12rpx;
}

/* 错误提示 */
.error-text {
  display: block;
  font-size: 24rpx;
  color: #FF4D4F;
  margin-top: 12rpx;
}

/* 提示区域 */
.tips-section {
  padding: 0 30rpx;
  margin-bottom: 40rpx;
}

.tip-item {
  display: flex;
  align-items: center;
  margin-bottom: 16rpx;
}

.tip-icon {
  font-size: 28rpx;
  margin-right: 12rpx;
}

.tip-text {
  font-size: 24rpx;
  color: #999;
}

/* 提交区域 */
.submit-section {
  padding: 0 30rpx;
}

.submit-btn {
  background: linear-gradient(135deg, #FF6B35 0%, #FF8F50 100%);
  color: #fff;
  border-radius: 50rpx;
  height: 96rpx;
  font-size: 34rpx;
  font-weight: 500;
  border: none;
  display: flex;
  justify-content: center;
  align-items: center;
  line-height: normal;
}

.submit-btn::after {
  border: none;
}

.submit-btn[disabled] {
  opacity: 0.6;
}
