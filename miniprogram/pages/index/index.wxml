<!-- 搜索栏 -->
<view class="search-bar">
  <view class="search-input">
    <text class="icon">🔍</text>
    <input
      placeholder="搜索地摊或商品"
      value="{{keyword}}"
      bindinput="onSearch"
      bindconfirm="onSearch"
    />
  </view>
  <view class="locate-btn" bindtap="onLocate">📍</view>
</view>

<!-- 地图区域 -->
<view class="map-container" wx:if="{{showMap}}">
  <map
    id="map"
    latitude="{{latitude}}"
    longitude="{{longitude}}"
    markers="{{markers}}"
    circles="{{circles}}"
    bindmarkertap="onMarkerTap"
    bindcallouttap="onMarkerTap"
    bindlabeltap="onMarkerTap"
    show-location
    scale="14"
  ></map>

  <!-- 地图覆盖按钮 -->
  <view class="map-buttons">
    <view class="btn btn-filter" bindtap="onToggleFilter">
      🔍
    </view>
  </view>
</view>

<!-- 列表区域 -->
<scroll-view
  class="list-container"
  scroll-y
  wx:if="{{showList}}"
  bindscrolltolower="onReachBottom"
  enable-back-to-top
>
  <stall-card
    wx:for="{{stalls}}"
    wx:key="_id"
    stall="{{item}}"
    show-reliability="{{false}}"
    show-distance="{{userLatitude ? true : false}}"
    bindtap="onStallTap"
  />

  <!-- 加载状态 -->
  <view class="loading-more" wx:if="{{loading}}">
    加载中...
  </view>

  <!-- 没有更多 -->
  <view class="no-more" wx:if="{{!hasMore && stalls.length > 0}}">
    没有更多了
  </view>

  <!-- 空状态 -->
  <view class="empty" wx:if="{{stalls.length === 0 && !loading}}">
    <image src="/images/empty.png" mode="aspectFit" />
    <text>暂无地摊信息</text>
  </view>
</scroll-view>

<!-- 筛选面板 -->
<view class="filter-panel" wx:if="{{showFilter}}">
  <view class="filter-mask" bindtap="onToggleFilter"></view>
  <view class="filter-content">
    <view class="filter-header">
      <text class="title">筛选</text>
      <text class="close" bindtap="onToggleFilter">✕</text>
    </view>

    <view class="filter-section">
      <text class="section-title">商品类型</text>
      <category-filter
        categories="{{categories}}"
        selected-id="{{selectedCategory}}"
        bindselect="onCategorySelect"
      />
    </view>

    <view class="filter-section">
      <text class="section-title">出摊时间</text>
      <time-filter
        selected-type="{{selectedTime}}"
        bindselect="onTimeSelect"
      />
    </view>
  </view>
</view>

<!-- 标记卡片预览 -->
<view wx:if="{{showMarkerCard && selectedStall}}" class="marker-card-overlay" bindtap="onCloseMarkerCard">
  <view class="marker-card" catchtap="preventBubble">
    <!-- 卡片头部 -->
    <view class="card-header">
      <view class="stall-info">
        <view class="category-tag" style="--cat-color: {{categoryColors[selectedStall.categoryId] || '#FF6B35'}}">
          <text class="category-icon">{{selectedStall.categoryIcon || '🏪'}}</text>
          <text class="category-text">{{selectedStall.categoryName || '其他'}}</text>
        </view>
        <text class="stall-name">{{selectedStall.displayName}}</text>
      </view>
      <text class="close-btn" bindtap="onCloseMarkerCard">✕</text>
    </view>
    
    <!-- 卡片内容 -->
    <view class="card-body">
      <!-- 图片 -->
      <view wx:if="{{selectedStall.images && selectedStall.images.length > 0}}" class="card-image">
        <image src="{{selectedStall.images[0]}}" mode="aspectFill" />
      </view>
      
      <!-- 信息 -->
      <view class="card-info">
        <!-- 商品标签 -->
        <view class="info-row goods-row" wx:if="{{selectedStall.goodsTags && selectedStall.goodsTags.length > 0}}">
          <text class="icon">📦</text>
          <text class="label">商品：</text>
          <view class="goods-tags">
            <text class="goods-tag" wx:for="{{selectedStall.goodsTags}}" wx:key="*this">{{item}}</text>
          </view>
        </view>
        <view class="info-row">
          <text class="icon">📍</text>
          <text class="label">地址：</text>
          <text class="text">{{selectedStall.address || '暂无'}}</text>
        </view>
        <view class="info-row">
          <text class="icon">🕐</text>
          <text class="label">时间：</text>
          <text class="text">{{selectedStall.scheduleDisplay || '时间待定'}}</text>
        </view>
        <!-- 可信度 -->
        <view class="reliability-row">
          <text wx:if="{{selectedStall.reliability === 0}}" class="reliability high">🟢 今日可能在</text>
          <text wx:elif="{{selectedStall.reliability === 1}}" class="reliability medium">🟡 最近没摆</text>
          <text wx:else class="reliability low">⚪ 信息过期</text>
        </view>
      </view>
    </view>
    
    <!-- 卡片底部 -->
    <view class="card-footer">
      <button class="btn-detail" bindtap="onGoToDetail">查看详情</button>
    </view>
  </view>
</view>

<!-- 欢迎弹窗 - 新用户获取昵称 -->
<view class="welcome-modal" wx:if="{{showWelcomeModal}}">
  <view class="welcome-mask" bindtap="onSkipWelcome"></view>
  <view class="welcome-content">
    <view class="welcome-header">
      <text class="welcome-emoji">🎉</text>
      <text class="welcome-title">欢迎来到摆地摊了么</text>
      <text class="welcome-desc">设置昵称，让我们认识你</text>
    </view>
    <view class="welcome-body">
      <!-- 昵称输入 -->
      <view class="welcome-input-wrap">
        <input
          class="welcome-nickname-input"
          type="nickname"
          placeholder="点击获取微信昵称"
          value="{{tempNickname}}"
          bindinput="onNicknameInput"
          bindblur="onNicknameConfirm"
        />
      </view>
      <text class="welcome-hint">点击输入框可使用微信昵称</text>
    </view>
    <view class="welcome-footer">
      <button class="welcome-btn welcome-btn-skip" bindtap="onSkipWelcome">稍后再说</button>
      <button class="welcome-btn welcome-btn-confirm" bindtap="onConfirmNickname">确认</button>
    </view>
  </view>
</view>
