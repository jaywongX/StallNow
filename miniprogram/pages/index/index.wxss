/* 搜索栏 */
.search-bar {
  display: flex;
  align-items: center;
  padding: 16rpx 20rpx;
  background-color: #FFF;
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 100;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.08);
}

.search-input {
  flex: 1;
  display: flex;
  align-items: center;
  background-color: #F5F5F5;
  border-radius: 32rpx;
  padding: 12rpx 24rpx;
  margin-right: 16rpx;
}

.search-input .icon {
  font-size: 32rpx;
  margin-right: 12rpx;
}

.search-input input {
  flex: 1;
  font-size: 28rpx;
}

.locate-btn {
  font-size: 40rpx;
  padding: 12rpx;
}

/* 地图容器 */
.map-container {
  position: fixed;
  top: 88rpx;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 1;
}

#map {
  width: 100%;
  height: 100%;
}

.map-buttons {
  position: fixed;
  right: 20rpx;
  bottom: 40rpx;
  display: flex;
  flex-direction: column;
  gap: 20rpx;
  z-index: 10;
}

.map-buttons .btn {
  width: 100rpx;
  height: 100rpx;
  background-color: #FFF;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.15);
}

/* 列表容器 */
.list-container {
  position: fixed;
  top: 88rpx;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 1;
  padding: 20rpx;
  overflow-y: auto;
}

.loading-more, .no-more {
  text-align: center;
  padding: 40rpx 0;
  color: #999;
  font-size: 26rpx;
}

.empty {
  text-align: center;
  padding: 120rpx 0;
}

.empty image {
  width: 240rpx;
  height: 240rpx;
  margin-bottom: 30rpx;
}

/* 筛选面板 */
.filter-panel {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 200;
}

.filter-mask {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.5);
}

.filter-content {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  background-color: #FFF;
  border-radius: 24rpx 24rpx 0 0;
  max-height: 80%;
  overflow-y: auto;
}

.filter-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 30rpx;
  border-bottom: 1rpx solid #F0F0F0;
}

.filter-header .title {
  font-size: 32rpx;
  font-weight: bold;
}

.filter-header .close {
  font-size: 40rpx;
  color: #999;
}

.filter-section {
  padding: 30rpx;
}

.section-title {
  display: block;
  font-size: 28rpx;
  color: #666;
  margin-bottom: 20rpx;
}
