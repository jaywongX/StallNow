/* 搜索栏 */
.search-bar {
  display: flex;
  align-items: center;
  padding: 16rpx 20rpx;
  background-color: #FFF;
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 100;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.08);
}

.search-input {
  flex: 1;
  display: flex;
  align-items: center;
  background-color: #F5F5F5;
  border-radius: 32rpx;
  padding: 12rpx 24rpx;
  margin-right: 16rpx;
}

.search-input .icon {
  font-size: 32rpx;
  margin-right: 12rpx;
}

.search-input input {
  flex: 1;
  font-size: 28rpx;
}

.locate-btn {
  font-size: 40rpx;
  padding: 12rpx;
}

/* 地图容器 */
.map-container {
  position: fixed;
  top: 88rpx;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 1;
}

#map {
  width: 100%;
  height: 100%;
}

.map-buttons {
  position: fixed;
  right: 20rpx;
  bottom: 40rpx;
  display: flex;
  flex-direction: column;
  gap: 20rpx;
  z-index: 10;
}

.map-buttons .btn {
  width: 100rpx;
  height: 100rpx;
  background-color: #FFF;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.15);
}

/* 列表容器 */
.list-container {
  position: fixed;
  top: 88rpx;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 1;
  padding: 20rpx;
  overflow-y: auto;
}

.loading-more, .no-more {
  text-align: center;
  padding: 40rpx 0;
  color: #999;
  font-size: 26rpx;
}

.empty {
  text-align: center;
  padding: 120rpx 0;
}

.empty image {
  width: 240rpx;
  height: 240rpx;
  margin-bottom: 30rpx;
}

/* 筛选面板 */
.filter-panel {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 200;
}

.filter-mask {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.5);
}

.filter-content {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  background-color: #FFF;
  border-radius: 24rpx 24rpx 0 0;
  max-height: 80%;
  overflow-y: auto;
}

.filter-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 30rpx;
  border-bottom: 1rpx solid #F0F0F0;
}

.filter-header .title {
  font-size: 32rpx;
  font-weight: bold;
}

.filter-header .close {
  font-size: 40rpx;
  color: #999;
}

.filter-section {
  padding: 30rpx;
}

.section-title {
  display: block;
  font-size: 28rpx;
  color: #666;
  margin-bottom: 20rpx;
}

/* 标记卡片预览 */
.marker-card-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.4);
  z-index: 500;
  display: flex;
  align-items: flex-end;
  justify-content: center;
  padding-bottom: 100rpx;
}

.marker-card {
  width: 90%;
  max-width: 680rpx;
  background: #fff;
  border-radius: 24rpx;
  box-shadow: 0 8rpx 40rpx rgba(0, 0, 0, 0.2);
  overflow: hidden;
  animation: cardSlideUp 0.3s ease;
}

@keyframes cardSlideUp {
  from {
    opacity: 0;
    transform: translateY(50rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

.card-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 24rpx 16rpx;
}

.stall-info {
  display: flex;
  align-items: center;
  flex: 1;
  overflow: hidden;
}

.category-tag {
  font-size: 22rpx;
  color: #fff;
  padding: 6rpx 14rpx;
  border-radius: 8rpx;
  margin-right: 12rpx;
  flex-shrink: 0;
}

.stall-name {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.close-btn {
  font-size: 36rpx;
  color: #999;
  padding: 0 10rpx;
  margin-left: 10rpx;
}

.card-body {
  display: flex;
  padding: 0 24rpx 20rpx;
}

.card-image {
  width: 160rpx;
  height: 160rpx;
  border-radius: 12rpx;
  overflow: hidden;
  flex-shrink: 0;
  margin-right: 20rpx;
}

.card-image image {
  width: 100%;
  height: 100%;
}

.card-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: center;
}

.info-row {
  display: flex;
  align-items: center;
  margin-bottom: 10rpx;
}

.info-row .icon {
  font-size: 28rpx;
  margin-right: 10rpx;
}

.info-row .text {
  font-size: 26rpx;
  color: #666;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.reliability-row {
  margin-top: 8rpx;
}

.reliability {
  font-size: 24rpx;
  padding: 6rpx 12rpx;
  border-radius: 8rpx;
}

.reliability.high {
  background: #E6F7E6;
  color: #52C41A;
}

.reliability.medium {
  background: #FFF7E6;
  color: #FAAD14;
}

.reliability.low {
  background: #F5F5F5;
  color: #999;
}

.card-footer {
  padding: 0 24rpx 24rpx;
}

.btn-detail {
  width: 100%;
  height: 80rpx;
  line-height: 80rpx;
  background: #FF6B35;
  color: #fff;
  font-size: 30rpx;
  border-radius: 40rpx;
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0;
  margin: 0;
}

