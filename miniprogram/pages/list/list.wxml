<!-- 搜索栏 -->
<view class="search-bar">
  <view class="search-input">
    <text class="icon">🔍</text>
    <input
      placeholder="搜索地摊或商品"
      value="{{keyword}}"
      bindinput="onSearch"
      bindconfirm="onSearch"
    />
  </view>
</view>

<!-- 筛选栏 -->
<view class="filter-bar">
  <!-- 第一行：分类筛选 -->
  <view class="filter-row category-row">
    <category-filter
      categories="{{categories}}"
      selected-id="{{selectedCategory}}"
      bindselect="onCategorySelect"
    />
  </view>
  
  <!-- 第二行：附近（距离）和筛选按钮 -->
  <view class="filter-row sub-filter-row">
    <view class="distance-filter" bindtap="onOpenDistanceFilter">
      <text class="distance-text {{selectedDistance !== '' ? 'active' : ''}}">{{selectedDistanceName}}</text>
      <text class="distance-icon">▼</text>
    </view>
    
    <!-- 排序/筛选按钮 -->
    <view class="sort-filter-btns">
      <view class="filter-btn {{sortBy !== 'default' || filterConfirmed || selectedTime ? 'active' : ''}}" bindtap="onOpenFilter">
        <text class="btn-text">{{sortBy === 'default' && !filterConfirmed && !selectedTime ? '排序/筛选' : '已筛选'}}</text>
        <text class="btn-icon">▼</text>
      </view>
    </view>
  </view>
</view>

<!-- 地摊列表 -->
<scroll-view
  class="list-container"
  scroll-y
  bindscrolltolower="onReachBottom"
  enable-back-to-top
>
  <view 
    wx:for="{{stalls}}"
    wx:key="_id"
    data-id="{{item._id}}"
    bindtap="onStallTap"
  >
    <stall-card
      stall="{{item}}"
      show-reliability="{{true}}"
      show-distance="{{userLatitude ? true : false}}"
    />
  </view>

  <!-- 加载状态 -->
  <view class="loading-more" wx:if="{{loading}}">
    加载中...
  </view>

  <!-- 没有更多 -->
  <view class="no-more" wx:if="{{!hasMore && stalls.length > 0}}">
    没有更多了
  </view>

  <!-- 空状态 -->
  <view class="empty" wx:if="{{stalls.length === 0 && !loading}}">
    <image src="/images/empty.png" mode="aspectFit" />
    <text>暂无地摊信息</text>
  </view>
</scroll-view>

<!-- 分类选择弹窗 -->
<view wx:if="{{showCategoryModal}}" class="filter-modal" bindtap="onCloseCategoryFilter">
  <view class="filter-modal-content" catchtap>
    <view class="filter-modal-header">
      <text class="modal-title">选择分类</text>
      <text class="modal-close" bindtap="onCloseCategoryFilter">✕</text>
    </view>
    
    <view class="filter-section">
      <view class="sort-options">
        <view 
          class="sort-item {{selectedCategory === '' ? 'active' : ''}}"
          data-id=""
          data-name="分类"
          bindtap="onCategorySelectFromModal"
        >
          <text class="sort-name">全部分类</text>
          <text wx:if="{{selectedCategory === ''}}" class="sort-check">✓</text>
        </view>
        <view 
          wx:for="{{categories}}" 
          wx:key="_id"
          class="sort-item {{selectedCategory === item._id ? 'active' : ''}}"
          data-id="{{item._id}}"
          data-name="{{item.name}}"
          bindtap="onCategorySelectFromModal"
        >
          <text class="sort-name">{{item.icon}} {{item.name}}</text>
          <text wx:if="{{selectedCategory === item._id}}" class="sort-check">✓</text>
        </view>
      </view>
    </view>
  </view>
</view>

<!-- 距离选择弹窗 -->
<view wx:if="{{showDistanceModal}}" class="filter-modal" bindtap="onCloseDistanceFilter">
  <view class="filter-modal-content" catchtap>
    <view class="filter-modal-header">
      <text class="modal-title">选择距离</text>
      <text class="modal-close" bindtap="onCloseDistanceFilter">✕</text>
    </view>
    
    <view class="filter-section">
      <view class="sort-options">
        <view 
          wx:for="{{distanceOptions}}" 
          wx:key="value"
          class="sort-item {{selectedDistance === item.value ? 'active' : ''}}"
          data-value="{{item.value}}"
          data-name="{{item.name}}"
          bindtap="onDistanceSelect"
        >
          <text class="sort-name">{{item.name}}</text>
          <text wx:if="{{selectedDistance === item.value}}" class="sort-check">✓</text>
        </view>
      </view>
    </view>
  </view>
</view>

<!-- 筛选/排序弹窗 -->
<view wx:if="{{showFilterModal}}" class="filter-modal" bindtap="onCloseFilter">
  <view class="filter-modal-content" catchtap>
    <view class="filter-modal-header">
      <text class="modal-title">筛选</text>
      <text class="modal-close" bindtap="onCloseFilter">✕</text>
    </view>
    
    <!-- 出摊时间 -->
    <view class="filter-section">
      <text class="section-title">出摊时间</text>
      <view class="sort-options">
        <view 
          wx:for="{{timeOptions}}" 
          wx:key="value"
          class="sort-item {{selectedTime === item.value ? 'active' : ''}}"
          data-value="{{item.value}}"
          bindtap="onTimeSelectFromModal"
        >
          <text class="sort-name">{{item.name}}</text>
          <text wx:if="{{selectedTime === item.value}}" class="sort-check">✓</text>
        </view>
      </view>
    </view>
    
    <!-- 排序选项 -->
    <view class="filter-section">
      <text class="section-title">排序方式</text>
      <view class="sort-options">
        <view 
          wx:for="{{sortOptions}}" 
          wx:key="id"
          class="sort-item {{sortBy === item.id ? 'active' : ''}}"
          data-id="{{item.id}}"
          bindtap="onSortSelect"
        >
          <text class="sort-name">{{item.name}}</text>
          <text wx:if="{{sortBy === item.id}}" class="sort-check">✓</text>
        </view>
      </view>
    </view>
    
    <!-- 筛选选项 -->
    <view class="filter-section">
      <text class="section-title">其他筛选</text>
      <view class="filter-options">
        <view 
          class="filter-option-item {{filterConfirmed ? 'active' : ''}}"
          data-id="confirmed"
          bindtap="onFilterToggle"
        >
          <text class="option-name">只看近期确认的摊位</text>
          <view class="option-checkbox {{filterConfirmed ? 'checked' : ''}}">
            <text wx:if="{{filterConfirmed}}">✓</text>
          </view>
        </view>
      </view>
    </view>
    
    <!-- 底部按钮 -->
    <view class="filter-modal-footer">
      <button class="btn-reset" bindtap="onFilterReset">重置</button>
      <button class="btn-apply" bindtap="onFilterApply">应用</button>
    </view>
  </view>
</view>
