<view class="container">
  <!-- 用户信息区 -->
  <view class="user-section">
    <view class="user-info">
      <!-- 头像获取按钮 -->
      <button class="avatar-btn" open-type="chooseAvatar" bindchooseavatar="onChooseAvatar">
        <image
          class="user-avatar"
          src="{{userInfo.avatarUrl || '/images/default-avatar.png'}}"
          mode="aspectFill"
        />
      </button>
      <view class="user-meta">
        <!-- 昵称输入框 -->
        <input
          class="nickname-input"
          type="nickname"
          placeholder="点击设置昵称"
          value="{{userInfo.nickName}}"
          bindblur="onNicknameBlur"
          bindinput="onNicknameInput"
        />
        <view class="user-badge" wx:if="{{role !== 'user'}}">
          <text class="badge-text">{{role === 'admin' ? '管理员' : '摊主'}}</text>
        </view>
      </view>
    </view>
    
    <!-- 城市选择 -->
    <view class="city-bar" bindtap="onCityTap">
      <text class="city-label">📍 所在城市</text>
      <text class="city-value">{{currentCity}}</text>
      <text class="arrow">></text>
    </view>
  </view>

  <!-- 用户功能 -->
  <view class="menu-section">
    <view class="section-title">我的功能</view>
    <view class="menu-list">
      <view class="menu-item" bindtap="onFavoritesTap">
        <view class="menu-left">
          <text class="menu-icon">⭐</text>
          <text class="menu-name">收藏的摊位</text>
        </view>
        <text class="menu-arrow">></text>
      </view>
    </view>
  </view>

  <!-- 辅助与合规 -->
  <view class="menu-section">
    <view class="section-title">辅助与合规</view>
    <view class="menu-list">
      <view class="menu-item" bindtap="onHelpTap">
        <view class="menu-left">
          <text class="menu-icon">📖</text>
          <text class="menu-name">使用说明</text>
        </view>
        <text class="menu-arrow">></text>
      </view>
      <view class="menu-item" bindtap="onAboutTap">
        <view class="menu-left">
          <text class="menu-icon">ℹ️</text>
          <text class="menu-name">关于我们</text>
        </view>
        <text class="menu-arrow">></text>
      </view>
      <view class="menu-item" bindtap="onPrivacyTap">
        <view class="menu-left">
          <text class="menu-icon">🔒</text>
          <text class="menu-name">隐私政策</text>
        </view>
        <text class="menu-arrow">></text>
      </view>
      <view class="menu-item" bindtap="onDisclaimerTap">
        <view class="menu-left">
          <text class="menu-icon">⚠️</text>
          <text class="menu-name">免责声明</text>
        </view>
        <text class="menu-arrow">></text>
      </view>
      <view class="menu-item" bindtap="onFeedbackTap">
        <view class="menu-left">
          <text class="menu-icon">💬</text>
          <text class="menu-name">意见反馈</text>
        </view>
        <text class="menu-arrow">></text>
      </view>
    </view>
  </view>

  <!-- 管理后台（仅管理员可见） -->
  <view class="menu-section" wx:if="{{isAdmin}}">
    <view class="section-title">管理员</view>
    <view class="menu-list">
      <view class="menu-item admin-item" bindtap="onAdminTap">
        <view class="menu-left">
          <text class="menu-icon">⚙️</text>
          <text class="menu-name">管理后台</text>
        </view>
        <text class="menu-arrow">></text>
      </view>
    </view>
  </view>

  <!-- 版本信息 -->
  <view class="version-info">
    <text>摆地摊了么 v1.0.3</text>
  </view>

  <!-- 使用说明弹窗 -->
  <view class="modal-mask" wx:if="{{showHelpModal}}" bindtap="onCloseHelpModal">
    <view class="modal-content" catchtap>
      <view class="modal-header">
        <text class="modal-title">使用说明</text>
        <text class="modal-close" bindtap="onCloseHelpModal">✕</text>
      </view>
      <view class="modal-body">
        <view class="help-item">
          <text class="help-num">1</text>
          <view class="help-text">
            <text class="help-title">附近</text>
            <text class="help-desc">查看周围的地摊，在地图上浏览摊位分布</text>
          </view>
        </view>
        <view class="help-item">
          <text class="help-num">2</text>
          <view class="help-text">
            <text class="help-title">逛摊</text>
            <text class="help-desc">浏览分类推荐，发现感兴趣的地摊</text>
          </view>
        </view>
        <view class="help-item">
          <text class="help-num">3</text>
          <view class="help-text">
            <text class="help-title">我是摊主</text>
            <text class="help-desc">摊主可在此入驻，管理自己的摊位信息</text>
          </view>
        </view>
        <view class="help-item">
          <text class="help-num">4</text>
          <view class="help-text">
            <text class="help-title">意见反馈</text>
            <text class="help-desc">有问题请在意见反馈中提交，我们会及时处理</text>
          </view>
        </view>
      </view>
      <view class="modal-footer">
        <button class="modal-btn" bindtap="onCloseHelpModal">知道了</button>
      </view>
    </view>
  </view>

  <!-- 免责声明弹窗 -->
  <view class="modal-mask" wx:if="{{showDisclaimerModal}}" bindtap="onCloseDisclaimerModal">
    <view class="modal-content disclaimer-modal" catchtap>
      <view class="modal-header">
        <text class="modal-title">免责声明</text>
        <text class="modal-close" bindtap="onCloseDisclaimerModal">✕</text>
      </view>
      <view class="modal-body">
        <view class="disclaimer-section">
          <text class="disclaimer-title">信息展示服务</text>
          <text class="disclaimer-text">本小程序仅提供地摊信息展示服务，不对地摊商品质量、交易行为等承担任何责任。</text>
        </view>
        <view class="disclaimer-section">
          <text class="disclaimer-title">风险提示</text>
          <text class="disclaimer-text">• 摊位信息由摊主或志愿收集提供，信息可能随时变化\n• 平台不参与任何交易，交易纠纷平台不承担责任\n• 请用户自行辨别信息真伪，谨慎交易\n• 以现场实际情况为准</text>
        </view>
        <view class="disclaimer-section">
          <text class="disclaimer-title">联系方式</text>
          <text class="disclaimer-text">联系方式由摊主自行提供，平台不保证联系方式的有效性，请谨慎使用。</text>
        </view>
      </view>
      <view class="modal-footer">
        <button class="modal-btn" bindtap="onCloseDisclaimerModal">我知道了</button>
      </view>
    </view>
  </view>
</view>
