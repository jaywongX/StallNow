/* 我的页面样式 */

.container {
  min-height: 100vh;
  background: #F5F5F5;
  padding-bottom: 40rpx;
}

/* 用户信息区 */
.user-section {
  background: linear-gradient(135deg, #FF6B35 0%, #FF8F50 100%);
  padding: 40rpx 30rpx 0;
}

.user-info {
  display: flex;
  align-items: center;
  padding-bottom: 40rpx;
}

.user-avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  border: 4rpx solid rgba(255,255,255,0.3);
  margin-right: 24rpx;
  background: #f0f0f0;
}

.user-meta {
  flex: 1;
}

.user-name {
  display: block;
  font-size: 40rpx;
  font-weight: bold;
  color: #fff;
  margin-bottom: 12rpx;
}

.user-badge {
  display: inline-block;
  background: rgba(255,255,255,0.2);
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
}

.badge-text {
  font-size: 22rpx;
  color: #fff;
}

.arrow {
  font-size: 32rpx;
  color: rgba(255,255,255,0.6);
}

/* 城市栏 */
.city-bar {
  display: flex;
  align-items: center;
  background: rgba(255,255,255,0.1);
  border-radius: 16rpx 16rpx 0 0;
  padding: 24rpx 30rpx;
}

.city-label {
  font-size: 28rpx;
  color: rgba(255,255,255,0.8);
  margin-right: 16rpx;
}

.city-value {
  flex: 1;
  font-size: 30rpx;
  color: #fff;
  font-weight: 500;
}

.city-bar .arrow {
  font-size: 28rpx;
}

/* 菜单区域 */
.menu-section {
  margin-top: 30rpx;
  padding: 0 30rpx;
}

.section-title {
  font-size: 28rpx;
  color: #999;
  margin-bottom: 16rpx;
  padding-left: 10rpx;
}

.menu-list {
  background: #fff;
  border-radius: 16rpx;
  overflow: hidden;
}

.menu-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 28rpx 30rpx;
  border-bottom: 1rpx solid #f5f5f5;
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-left {
  display: flex;
  align-items: center;
}

.menu-icon {
  font-size: 32rpx;
  margin-right: 20rpx;
}

.menu-name {
  font-size: 30rpx;
  color: #333;
}

.menu-arrow {
  font-size: 28rpx;
  color: #ccc;
}

/* 管理员菜单 */
.admin-item {
  background: #FFF5F2;
}

.admin-item .menu-name {
  color: #FF6B35;
  font-weight: 500;
}

/* 版本信息 */
.version-info {
  text-align: center;
  margin-top: 60rpx;
  padding: 30rpx;
}

.version-info text {
  font-size: 24rpx;
  color: #ccc;
}

/* 使用说明弹窗 */
.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.6);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
}

.modal-content {
  background: #fff;
  border-radius: 24rpx;
  width: 80%;
  max-width: 600rpx;
  max-height: 70vh;
  display: flex;
  flex-direction: column;
}

.modal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 30rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.modal-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
}

.modal-close {
  font-size: 36rpx;
  color: #999;
  padding: 10rpx;
}

.modal-body {
  padding: 30rpx;
  overflow-y: auto;
  max-height: 50vh;
}

.help-item {
  display: flex;
  align-items: flex-start;
  margin-bottom: 30rpx;
}

.help-item:last-child {
  margin-bottom: 0;
}

.help-num {
  width: 48rpx;
  height: 48rpx;
  background: #FF6B35;
  color: #fff;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  font-weight: bold;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.help-text {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.help-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 8rpx;
}

.help-desc {
  font-size: 26rpx;
  color: #666;
  line-height: 1.5;
}

.modal-footer {
  padding: 20rpx 30rpx 30rpx;
}

.modal-btn {
  background: #FF6B35;
  color: #fff;
  border-radius: 40rpx;
  font-size: 30rpx;
  height: 80rpx;
  line-height: 80rpx;
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
}

/* 免责声明弹窗 */
.disclaimer-modal .modal-body {
  padding: 20rpx 30rpx;
}

.disclaimer-section {
  margin-bottom: 24rpx;
}

.disclaimer-section:last-child {
  margin-bottom: 0;
}

.disclaimer-title {
  display: block;
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 12rpx;
}

.disclaimer-text {
  display: block;
  font-size: 28rpx;
  color: #666;
  line-height: 1.6;
  white-space: pre-wrap;
}
