/* 我的页面样式 */

.container {
  min-height: 100vh;
  background: #F5F5F5;
  padding-bottom: 40rpx;
}

/* 用户信息区 */
.user-section {
  background: linear-gradient(135deg, #FF6B35 0%, #FF8F50 100%);
  padding: 40rpx 30rpx 0;
}

.user-info {
  display: flex;
  align-items: center;
  padding-bottom: 40rpx;
}

.user-avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  border: 4rpx solid rgba(255,255,255,0.3);
  margin-right: 24rpx;
  background: #f0f0f0;
}

.user-meta {
  flex: 1;
}

.user-name {
  display: block;
  font-size: 40rpx;
  font-weight: bold;
  color: #fff;
  margin-bottom: 12rpx;
}

.user-badge {
  display: inline-block;
  background: rgba(255,255,255,0.2);
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
}

.badge-text {
  font-size: 22rpx;
  color: #fff;
}

.arrow {
  font-size: 32rpx;
  color: rgba(255,255,255,0.6);
}

/* 城市栏 */
.city-bar {
  display: flex;
  align-items: center;
  background: rgba(255,255,255,0.1);
  border-radius: 16rpx 16rpx 0 0;
  padding: 24rpx 30rpx;
}

.city-label {
  font-size: 28rpx;
  color: rgba(255,255,255,0.8);
  margin-right: 16rpx;
}

.city-value {
  flex: 1;
  font-size: 30rpx;
  color: #fff;
  font-weight: 500;
}

.city-bar .arrow {
  font-size: 28rpx;
}

/* 菜单区域 */
.menu-section {
  margin-top: 30rpx;
  padding: 0 30rpx;
}

.section-title {
  font-size: 28rpx;
  color: #999;
  margin-bottom: 16rpx;
  padding-left: 10rpx;
}

.menu-list {
  background: #fff;
  border-radius: 16rpx;
  overflow: hidden;
}

.menu-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 28rpx 30rpx;
  border-bottom: 1rpx solid #f5f5f5;
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-left {
  display: flex;
  align-items: center;
}

.menu-icon {
  font-size: 32rpx;
  margin-right: 20rpx;
}

.menu-name {
  font-size: 30rpx;
  color: #333;
}

.menu-arrow {
  font-size: 28rpx;
  color: #ccc;
}

/* 管理员菜单 */
.admin-item {
  background: #FFF5F2;
}

.admin-item .menu-name {
  color: #FF6B35;
  font-weight: 500;
}

/* 版本信息 */
.version-info {
  text-align: center;
  margin-top: 60rpx;
  padding: 30rpx;
}

.version-info text {
  font-size: 24rpx;
  color: #ccc;
}
