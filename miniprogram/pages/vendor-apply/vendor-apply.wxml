<wxs src="./vendor-apply.wxs" module="helper" />

<view class="container">
  <!-- 页面标题 -->
  <view class="page-header">
    <text class="header-title">填写摊位信息</text>
    <text class="header-subtitle">信息越详细，越容易被人找到</text>
  </view>

  <!-- 表单 -->
  <view class="form-section">
    <!-- Step 1: 摊位类型 -->
    <view class="form-group">
      <view class="group-header">
        <text class="group-title">你卖什么？</text>
        <text class="required">*</text>
      </view>
      <view class="category-grid">
        <view 
          wx:for="{{categories}}" 
          wx:key="id"
          class="category-item {{form.categoryId === item.id ? 'active' : ''}}"
          data-id="{{item.id}}"
          data-name="{{item.name}}"
          bindtap="onCategorySelect"
        >
          <text class="category-icon">{{item.icon}}</text>
          <text class="category-name">{{item.name}}</text>
        </view>
      </view>
      <text wx:if="{{errors.category}}" class="error-text">{{errors.category}}</text>
    </view>

    <!-- Step 2: 常见商品 -->
    <view class="form-group" wx:if="{{form.categoryId}}">
      <view class="group-header">
        <text class="group-title">常见商品（多选）</text>
        <text class="required">*</text>
      </view>
      <view class="tags-container">
<view 
        wx:for="{{currentGoodsOptions}}" 
        wx:key="*this"
        class="tag-item {{helper.isGoodsTagSelected(form.goodsTags, item) ? 'active' : ''}}"
        data-tag="{{item}}"
        bindtap="onGoodsTagSelect"
      >
        {{item}}
      </view>
      </view>
      <text class="tags-hint">已选择 {{form.goodsTags.length}}/5 个</text>
      <text wx:if="{{errors.goods}}" class="error-text">{{errors.goods}}</text>
    </view>

    <!-- Step 3: 定位位置（必选） -->
    <view class="form-group">
      <view class="group-header">
        <text class="group-title">摊位定位</text>
        <text class="required">*</text>
      </view>
      
      <!-- 定位选择区域 -->
      <view class="location-selector" bindtap="{{form.location ? 'onReselectLocation' : 'onSelectLocation'}}">
        <view wx:if="{{!form.location}}" class="location-empty">
          <text class="location-icon">📍</text>
          <text class="location-text">点击选择摊位位置</text>
          <text class="location-hint">在地图上标记您的摊位位置</text>
        </view>
        
        <view wx:if="{{form.location}}" class="location-selected">
          <view class="location-header">
            <text class="location-name">{{form.location.name || '已选择位置'}}</text>
            <text class="location-change">重新选择</text>
          </view>
          <text class="location-address">{{form.location.address}}</text>
          <view class="location-coords">
            <text>纬度: {{form.location.latitude.toFixed(4)}}  经度: {{form.location.longitude.toFixed(4)}}</text>
          </view>
        </view>
      </view>
      
      <text class="input-hint">点击上方区域，在地图上选择您的摊位位置</text>
      <text wx:if="{{errors.location}}" class="error-text">{{errors.location}}</text>
    </view>

    <!-- Step 4: 常出没区域（可选） -->
    <view class="form-group">
      <view class="group-header">
        <text class="group-title">常出没区域</text>
        <text class="optional">（选填）</text>
      </view>
      <input 
        class="form-input"
        placeholder="例如：老街夜市、万达广场附近"
        value="{{form.address}}"
        bindinput="onAddressInput"
      />
      <text class="input-hint">填写常出没的大致区域，帮助用户更容易找到你</text>
    </view>

    <!-- Step 4: 出摊时间 -->
    <view class="form-group">
      <view class="group-header">
        <text class="group-title">一般什么时候出摊？</text>
        <text class="required">*</text>
      </view>
      <view class="schedule-grid">
        <view 
          wx:for="{{scheduleOptions}}" 
          wx:key="id"
          class="schedule-item {{helper.isScheduleSelected(form.scheduleTypes, item.id) ? 'active' : ''}}"
          data-id="{{item.id}}"
          bindtap="onScheduleSelect"
        >
          <text class="schedule-icon">{{item.icon}}</text>
          <text class="schedule-name">{{item.name}}</text>
        </view>
      </view>
      
      <!-- 自定义时间段选择（选择"不固定"时显示） -->
      <view class="custom-time-section" wx:if="{{helper.isScheduleSelected(form.scheduleTypes, 'unfixed')}}">
        <text class="custom-time-label">选择出摊时间段：</text>
        <view class="time-picker-row">
          <picker mode="selector" range="{{timePickerRange}}" bindchange="onCustomTimeStartChange">
            <view class="time-picker-btn">
              <text class="time-text">{{form.customTimeStart || '开始时间'}}</text>
              <text class="time-icon">▼</text>
            </view>
          </picker>
          <text class="time-separator">至</text>
          <picker mode="selector" range="{{timePickerRange}}" bindchange="onCustomTimeEndChange">
            <view class="time-picker-btn">
              <text class="time-text">{{form.customTimeEnd || '结束时间'}}</text>
              <text class="time-icon">▼</text>
            </view>
          </picker>
        </view>
      </view>
      
      <text wx:if="{{errors.schedule}}" class="error-text">{{errors.schedule}}</text>
    </view>

    <!-- Step 5: 摊位照片（选填） -->
    <view class="form-group">
      <view class="group-header">
        <text class="group-title">摊位照片</text>
        <text class="optional">（选填，最多3张）</text>
      </view>
      <!-- 合规提示 -->
      <view class="compliance-notice">
        <text class="notice-icon">💡</text>
        <view class="notice-content">
          <text class="notice-title">请上传摊位实拍照片</text>
          <text class="notice-text">照片请不要包含：价格标签、收款码、促销广告</text>
        </view>
      </view>
      <view class="image-upload-container">
        <view 
          class="image-item" 
          wx:for="{{form.images}}" 
          wx:key="index"
          data-index="{{index}}"
          bindtap="onPreviewImage"
        >
          <image src="{{item}}" mode="aspectFill" />
          <view class="delete-btn" data-index="{{index}}" catchtap="onDeleteImage">×</view>
        </view>
        <view 
          class="upload-btn-large"
          bindtap="onChooseImages"
          wx:if="{{form.images.length < 3}}"
        >
          <text class="icon">📷</text>
          <text class="text">上传照片</text>
          <text class="sub-text">{{form.images.length}}/3</text>
        </view>
      </view>
      <text class="input-hint">上传摊位实拍照片，帮助大家认出你</text>
    </view>

    <!-- Step 6: 摊位称呼（选填） -->
    <view class="form-group">
      <view class="group-header">
        <text class="group-title">摊位称呼</text>
        <text class="optional">（选填）</text>
      </view>
      <input 
        class="form-input"
        placeholder="例如：老王烧烤、广场手工摊"
        value="{{form.displayName}}"
        bindinput="onNameInput"
      />
      <!-- 合规提示 -->
      <view class="compliance-notice-small">
        <text class="notice-icon-small">💡</text>
        <text class="notice-text-small">请不要包含价格信息、促销用语、联系方式</text>
      </view>
      <text class="input-hint">不填将由系统自动生成</text>
    </view>

    <!-- Step 6: 联系方式（选填） -->
    <view class="form-group">
      <view class="group-header">
        <text class="group-title">联系方式</text>
        <text class="optional">（选填，仅用于用户联系你）</text>
      </view>
      <view class="contact-inputs">
        <input 
          class="form-input"
          type="number"
          placeholder="手机号码"
          value="{{form.phone}}"
          bindinput="onPhoneInput"
        />
        <input 
          class="form-input"
          placeholder="微信号"
          value="{{form.wechatId}}"
          bindinput="onWechatInput"
        />
      </view>
    </view>
  </view>

  <!-- 提交按钮 -->
  <view class="submit-section">
    <button class="submit-btn" bindtap="onSubmit">提交申请</button>
    <text class="submit-tips">提交后需等待审核，审核通过后即可管理摊位</text>
  </view>
</view>

<!-- 隐藏的 canvas 用于图片压缩 -->
<canvas canvas-id="compressCanvas" class="compress-canvas"></canvas>
