/* 入驻申请表单样式 */

.container {
  min-height: 100vh;
  background: #F5F5F5;
  padding-bottom: 60rpx;
}

/* 页面头部 */
.page-header {
  background: linear-gradient(135deg, #FF6B35 0%, #FF8F50 100%);
  padding: 60rpx 30rpx;
  text-align: center;
}

.header-title {
  display: block;
  font-size: 40rpx;
  font-weight: bold;
  color: #fff;
  margin-bottom: 12rpx;
}

.header-subtitle {
  display: block;
  font-size: 26rpx;
  color: rgba(255,255,255,0.8);
}

/* 表单区域 */
.form-section {
  padding: 30rpx;
}

.form-group {
  background: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 24rpx;
}

.group-header {
  display: flex;
  align-items: center;
  margin-bottom: 24rpx;
}

.group-title {
  font-size: 32rpx;
  font-weight: 500;
  color: #333;
}

.required {
  color: #FF6B35;
  margin-left: 8rpx;
  font-size: 28rpx;
}

.optional {
  color: #999;
  margin-left: 8rpx;
  font-size: 24rpx;
}

/* 分类网格 */
.category-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
}

.category-item {
  width: calc(33.33% - 14rpx);
  background: #F8F8F8;
  border-radius: 12rpx;
  padding: 30rpx 0;
  text-align: center;
  border: 2rpx solid transparent;
  transition: all 0.3s;
}

.category-item.active {
  background: #FFF5F2;
  border-color: #FF6B35;
}

.category-icon {
  display: block;
  font-size: 48rpx;
  margin-bottom: 12rpx;
}

.category-name {
  display: block;
  font-size: 26rpx;
  color: #333;
}

.category-item.active .category-name {
  color: #FF6B35;
  font-weight: 500;
}

/* 商品标签 */
.tags-container {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.tag-item {
  padding: 16rpx 28rpx;
  background: #F5F5F5;
  border-radius: 30rpx;
  font-size: 26rpx;
  color: #666;
  border: 2rpx solid transparent;
}

.tag-item.active {
  background: #FFF5F2;
  border-color: #FF6B35;
  color: #FF6B35;
}

.tags-hint {
  display: block;
  font-size: 24rpx;
  color: #999;
  margin-top: 16rpx;
}

/* 表单输入 */
.form-input {
  width: 100%;
  height: 88rpx;
  background: #F8F8F8;
  border-radius: 12rpx;
  padding: 0 24rpx;
  font-size: 28rpx;
  color: #333;
  box-sizing: border-box;
}

.input-hint {
  display: block;
  font-size: 24rpx;
  color: #999;
  margin-top: 12rpx;
}

/* 时间选择 */
.schedule-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
}

.schedule-item {
  width: calc(25% - 15rpx);
  background: #F8F8F8;
  border-radius: 12rpx;
  padding: 24rpx 0;
  text-align: center;
  border: 2rpx solid transparent;
}

.schedule-item.active {
  background: #FFF5F2;
  border-color: #FF6B35;
}

.schedule-icon {
  display: block;
  font-size: 40rpx;
  margin-bottom: 8rpx;
}

.schedule-name {
  display: block;
  font-size: 24rpx;
  color: #666;
}

.schedule-item.active .schedule-name {
  color: #FF6B35;
  font-weight: 500;
}

/* 联系方式 */
.contact-inputs .form-input {
  margin-bottom: 20rpx;
}

.contact-inputs .form-input:last-child {
  margin-bottom: 0;
}

/* 定位选择器 */
.location-selector {
  background: #F8F8F8;
  border-radius: 12rpx;
  padding: 30rpx;
  min-height: 120rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.location-empty {
  text-align: center;
}

.location-icon {
  display: block;
  font-size: 48rpx;
  margin-bottom: 12rpx;
}

.location-text {
  display: block;
  font-size: 28rpx;
  color: #333;
  margin-bottom: 8rpx;
}

.location-hint {
  display: block;
  font-size: 24rpx;
  color: #999;
}

.location-loading {
  text-align: center;
}

.loading-icon {
  display: block;
  font-size: 48rpx;
  margin-bottom: 12rpx;
}

.loading-text {
  display: block;
  font-size: 28rpx;
  color: #666;
}

.location-selected {
  width: 100%;
}

.location-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12rpx;
}

.location-name {
  font-size: 30rpx;
  font-weight: 500;
  color: #333;
}

.location-change {
  font-size: 26rpx;
  color: #FF6B35;
}

.location-address {
  display: block;
  font-size: 26rpx;
  color: #666;
  margin-bottom: 8rpx;
}

.location-coords {
  font-size: 22rpx;
  color: #999;
}

/* 错误提示 */
.error-text {
  display: block;
  font-size: 24rpx;
  color: #FF4D4F;
  margin-top: 12rpx;
}

/* 提交区域 */
.submit-section {
  padding: 0 30rpx;
  margin-top: 40rpx;
}

.submit-btn {
  background: linear-gradient(135deg, #FF6B35 0%, #FF8F50 100%);
  color: #fff;
  border-radius: 50rpx;
  height: 96rpx;
  font-size: 34rpx;
  font-weight: 500;
  border: none;
  display: flex;
  justify-content: center;  /* 水平居中 */
  align-items: center;      /* 垂直居中 */
  /* 移除原来的 line-height */
  line-height: normal;
}

.submit-btn::after {
  border: none;
}

.submit-tips {
  display: block;
  text-align: center;
  font-size: 24rpx;
  color: #999;
  margin-top: 20rpx;
}
