/* 入驻申请表单样式 */

.container {
  min-height: 100vh;
  background: #F5F5F5;
  padding-bottom: 60rpx;
}

/* 页面头部 */
.page-header {
  background: linear-gradient(135deg, #FF6B35 0%, #FF8F50 100%);
  padding: 60rpx 30rpx;
  text-align: center;
}

.header-title {
  display: block;
  font-size: 40rpx;
  font-weight: bold;
  color: #fff;
  margin-bottom: 12rpx;
}

.header-subtitle {
  display: block;
  font-size: 26rpx;
  color: rgba(255,255,255,0.8);
}

/* 表单区域 */
.form-section {
  padding: 30rpx;
}

.form-group {
  background: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 24rpx;
}

.group-header {
  display: flex;
  align-items: center;
  margin-bottom: 24rpx;
}

.group-title {
  font-size: 32rpx;
  font-weight: 500;
  color: #333;
}

.required {
  color: #FF6B35;
  margin-left: 8rpx;
  font-size: 28rpx;
}

.optional {
  color: #999;
  margin-left: 8rpx;
  font-size: 24rpx;
}

/* 分类网格 */
.category-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
}

.category-item {
  width: calc(33.33% - 14rpx);
  background: #F8F8F8;
  border-radius: 12rpx;
  padding: 30rpx 0;
  text-align: center;
  border: 2rpx solid transparent;
  transition: all 0.3s;
}

.category-item.active {
  background: #FFF5F2;
  border-color: #FF6B35;
}

.category-icon {
  display: block;
  font-size: 48rpx;
  margin-bottom: 12rpx;
}

.category-name {
  display: block;
  font-size: 26rpx;
  color: #333;
}

.category-item.active .category-name {
  color: #FF6B35;
  font-weight: 500;
}

/* 商品标签 */
.tags-container {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.tag-item {
  padding: 16rpx 28rpx;
  background: #F5F5F5;
  border-radius: 30rpx;
  font-size: 26rpx;
  color: #666;
  border: 2rpx solid transparent;
}

.tag-item.active {
  background: #FFF5F2;
  border-color: #FF6B35;
  color: #FF6B35;
}

.tags-hint {
  display: block;
  font-size: 24rpx;
  color: #999;
  margin-top: 16rpx;
}

/* 自定义商品输入 */
.custom-goods-section {
  margin-top: 24rpx;
  padding-top: 24rpx;
  border-top: 1rpx solid #F0F0F0;
}

.custom-goods-label {
  display: block;
  font-size: 26rpx;
  color: #666;
  margin-bottom: 16rpx;
}

.custom-goods-input-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.custom-goods-input {
  flex: 1;
  height: 72rpx;
  background: #F8F8F8;
  border-radius: 8rpx;
  padding: 0 20rpx;
  font-size: 26rpx;
}

.custom-goods-add-btn {
  padding: 16rpx 28rpx;
  background: #FF6B35;
  color: #fff;
  border-radius: 8rpx;
  font-size: 26rpx;
  white-space: nowrap;
}

/* 表单输入 */
.form-input {
  width: 100%;
  height: 88rpx;
  background: #F8F8F8;
  border-radius: 12rpx;
  padding: 0 24rpx;
  font-size: 28rpx;
  color: #333;
  box-sizing: border-box;
}

.input-hint {
  display: block;
  font-size: 24rpx;
  color: #999;
  margin-top: 12rpx;
}

/* 时间选择 */
.schedule-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
}

.schedule-item {
  width: calc(25% - 15rpx);
  background: #F8F8F8;
  border-radius: 12rpx;
  padding: 24rpx 0;
  text-align: center;
  border: 2rpx solid transparent;
}

.schedule-item.active {
  background: #FFF5F2;
  border-color: #FF6B35;
}

.schedule-icon {
  display: block;
  font-size: 40rpx;
  margin-bottom: 8rpx;
}

.schedule-name {
  display: block;
  font-size: 24rpx;
  color: #666;
}

.schedule-item.active .schedule-name {
  color: #FF6B35;
  font-weight: 500;
}

/* 联系方式 */
.contact-inputs .form-input {
  margin-bottom: 20rpx;
}

.contact-inputs .form-input:last-child {
  margin-bottom: 0;
}

/* 定位选择器 */
.location-selector {
  background: #F8F8F8;
  border-radius: 12rpx;
  padding: 30rpx;
  min-height: 120rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.location-empty {
  text-align: center;
}

.location-icon {
  display: block;
  font-size: 48rpx;
  margin-bottom: 12rpx;
}

.location-text {
  display: block;
  font-size: 28rpx;
  color: #333;
  margin-bottom: 8rpx;
}

.location-hint {
  display: block;
  font-size: 24rpx;
  color: #999;
}

.location-loading {
  text-align: center;
}

.loading-icon {
  display: block;
  font-size: 48rpx;
  margin-bottom: 12rpx;
}

.loading-text {
  display: block;
  font-size: 28rpx;
  color: #666;
}

.location-selected {
  width: 100%;
}

.location-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12rpx;
}

.location-name {
  font-size: 30rpx;
  font-weight: 500;
  color: #333;
}

.location-change {
  font-size: 26rpx;
  color: #FF6B35;
}

.location-address {
  display: block;
  font-size: 26rpx;
  color: #666;
  margin-bottom: 8rpx;
}

.location-coords {
  font-size: 22rpx;
  color: #999;
}

/* 错误提示 */
.error-text {
  display: block;
  font-size: 24rpx;
  color: #FF4D4F;
  margin-top: 12rpx;
}

/* 提交区域 */
.submit-section {
  padding: 0 30rpx;
  margin-top: 40rpx;
}

.submit-btn {
  background: linear-gradient(135deg, #FF6B35 0%, #FF8F50 100%);
  color: #fff;
  border-radius: 50rpx;
  height: 96rpx;
  font-size: 34rpx;
  font-weight: 500;
  border: none;
  display: flex;
  justify-content: center;  /* 水平居中 */
  align-items: center;      /* 垂直居中 */
  /* 移除原来的 line-height */
  line-height: normal;
}

.submit-btn::after {
  border: none;
}

.submit-tips {
  display: block;
  text-align: center;
  font-size: 24rpx;
  color: #999;
  margin-top: 20rpx;
}

/* 图片上传 */
.image-upload-container {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
}

.image-item {
  position: relative;
  width: 200rpx;
  height: 200rpx;
  border-radius: 12rpx;
  overflow: hidden;
  background: #F8F8F8;
}

.image-item image {
  width: 100%;
  height: 100%;
}

.delete-btn {
  position: absolute;
  top: 8rpx;
  right: 8rpx;
  width: 40rpx;
  height: 40rpx;
  background: rgba(0,0,0,0.5);
  color: #fff;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  line-height: 1;
}

.upload-btn-large {
  width: 200rpx;
  height: 200rpx;
  background: #F8F8F8;
  border-radius: 12rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  border: 2rpx dashed #DDD;
}

.upload-btn-large .icon {
  font-size: 48rpx;
  margin-bottom: 12rpx;
}

.upload-btn-large .text {
  font-size: 26rpx;
  color: #666;
  margin-bottom: 8rpx;
}

.upload-btn-large .sub-text {
  font-size: 22rpx;
  color: #999;
}

/* 隐藏的 canvas 用于图片压缩 */
.compress-canvas {
  position: fixed;
  left: -9999px;
  top: -9999px;
  width: 800px;
  height: 800px;
}

/* 自定义时间段选择 */
.custom-time-section {
  margin-top: 24rpx;
  padding: 24rpx;
  background: #FFF8F5;
  border-radius: 12rpx;
  border: 2rpx solid #FFD4C7;
}

.custom-time-label {
  display: block;
  font-size: 28rpx;
  color: #FF6B35;
  margin-bottom: 20rpx;
  font-weight: 500;
}

.time-picker-row {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 20rpx;
}

.time-picker-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 20rpx 32rpx;
  background: #fff;
  border-radius: 8rpx;
  border: 2rpx solid #FF6B35;
  min-width: 180rpx;
}

.time-text {
  font-size: 28rpx;
  color: #333;
  margin-right: 12rpx;
}

.time-icon {
  font-size: 20rpx;
  color: #FF6B35;
}

.time-separator {
  font-size: 28rpx;
  color: #666;
  font-weight: 500;
}

/* 合规提示 */
.compliance-notice {
  display: flex;
  align-items: flex-start;
  background: #FFF7E6;
  border-radius: 12rpx;
  padding: 20rpx;
  margin-bottom: 20rpx;
}

.notice-icon {
  font-size: 36rpx;
  margin-right: 16rpx;
  flex-shrink: 0;
}

.notice-content {
  flex: 1;
}

.notice-title {
  display: block;
  font-size: 28rpx;
  font-weight: 500;
  color: #D48806;
  margin-bottom: 6rpx;
}

.notice-text {
  display: block;
  font-size: 24rpx;
  color: #D48806;
  line-height: 1.5;
}

/* 小型合规提示 */
.compliance-notice-small {
  display: flex;
  align-items: center;
  background: #FFF7E6;
  border-radius: 8rpx;
  padding: 12rpx 16rpx;
  margin: 12rpx 0;
}

.notice-icon-small {
  font-size: 28rpx;
  margin-right: 10rpx;
}

.notice-text-small {
  font-size: 24rpx;
  color: #D48806;
}
