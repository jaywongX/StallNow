.container {
  padding-bottom: 140rpx;
  background: #f5f5f5;
  min-height: 100vh;
}

/* 加载状态 */
.loading-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 100rpx 0;
}

.loading-icon {
  width: 60rpx;
  height: 60rpx;
  border: 4rpx solid #f3f3f3;
  border-top: 4rpx solid #FF6B35;
  border-radius: 50%;
  animation: spin 1s linear infinite;
}

@keyframes spin {
  0% { transform: rotate(0deg); }
  100% { transform: rotate(360deg); }
}

.loading-text {
  margin-top: 20rpx;
  color: #999;
  font-size: 28rpx;
}

/* 表单容器 */
.form-container {
  padding: 20rpx;
}

.form-section {
  background: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 20rpx;
}

.section-desc {
  font-size: 26rpx;
  color: #999;
  margin-bottom: 20rpx;
  line-height: 1.5;
}

.required {
  color: #FF6B35;
}

.error-text {
  color: #FF6B35;
  font-size: 26rpx;
  margin-top: 10rpx;
}

/* 分类展示（只读） */
.category-display {
  display: flex;
  align-items: center;
  padding: 30rpx;
  background: #f9f9f9;
  border-radius: 12rpx;
}

.category-icon {
  font-size: 48rpx;
  margin-right: 20rpx;
}

.category-name {
  font-size: 30rpx;
  color: #666;
}

/* 商品标签 */
.tags-container {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.tag {
  padding: 12rpx 24rpx;
  background: #f5f5f5;
  border-radius: 32rpx;
  font-size: 26rpx;
  color: #666;
  transition: all 0.3s;
}

.tag.active {
  background: #FF6B35;
  color: #fff;
}

/* 自定义商品输入 */
.custom-goods-section {
  margin-top: 24rpx;
  padding-top: 24rpx;
  border-top: 1rpx solid #f0f0f0;
}

.custom-goods-label {
  display: block;
  font-size: 26rpx;
  color: #666;
  margin-bottom: 16rpx;
}

.custom-goods-input-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.custom-goods-input {
  flex: 1;
  height: 72rpx;
  background: #f9f9f9;
  border-radius: 8rpx;
  padding: 0 20rpx;
  font-size: 26rpx;
}

.custom-goods-add-btn {
  padding: 16rpx 28rpx;
  background: #FF6B35;
  color: #fff;
  border-radius: 8rpx;
  font-size: 26rpx;
  white-space: nowrap;
}

/* 输入框 */
.input {
  width: 100%;
  height: 80rpx;
  padding: 0 24rpx;
  background: #f9f9f9;
  border-radius: 12rpx;
  font-size: 28rpx;
  color: #333;
  box-sizing: border-box;
}

/* 出摊时间 */
.schedule-options {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
}

.schedule-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  width: 140rpx;
  height: 140rpx;
  background: #f9f9f9;
  border-radius: 16rpx;
  border: 2rpx solid transparent;
  transition: all 0.3s;
}

.schedule-item.active {
  background: #FFF5F2;
  border-color: #FF6B35;
}

.schedule-icon {
  font-size: 48rpx;
  margin-bottom: 8rpx;
}

.schedule-name {
  font-size: 26rpx;
  color: #666;
}

.schedule-item.active .schedule-name {
  color: #FF6B35;
}

/* 自定义时间 */
.custom-time-section {
  margin-top: 20rpx;
  padding: 20rpx;
  background: #f9f9f9;
  border-radius: 12rpx;
}

.time-picker-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.time-picker {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 20rpx;
  background: #fff;
  border-radius: 12rpx;
}

.time-label {
  font-size: 24rpx;
  color: #999;
  margin-bottom: 8rpx;
}

.time-value {
  font-size: 30rpx;
  color: #333;
  font-weight: 500;
}

.time-separator {
  padding: 0 20rpx;
  font-size: 28rpx;
  color: #999;
}

/* 图片上传 */
.images-container {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
}

.image-item {
  position: relative;
  width: 200rpx;
  height: 200rpx;
  border-radius: 12rpx;
  overflow: hidden;
}

.image-item image {
  width: 100%;
  height: 100%;
}

.delete-btn {
  position: absolute;
  top: 8rpx;
  right: 8rpx;
  width: 40rpx;
  height: 40rpx;
  background: rgba(0,0,0,0.5);
  color: #fff;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
}

.upload-btn {
  width: 200rpx;
  height: 200rpx;
  background: #f9f9f9;
  border: 2rpx dashed #ddd;
  border-radius: 12rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.upload-icon {
  font-size: 60rpx;
  color: #ccc;
  margin-bottom: 10rpx;
}

.upload-text {
  font-size: 26rpx;
  color: #999;
}

/* 联系方式 */
.contact-section {
  background: #f9f9f9;
  border-radius: 12rpx;
  padding: 0 24rpx;
}

.contact-item {
  display: flex;
  align-items: center;
  padding: 24rpx 0;
  border-bottom: 1rpx solid #eee;
}

.contact-item:last-child {
  border-bottom: none;
}

.contact-label {
  width: 100rpx;
  font-size: 28rpx;
  color: #666;
}

.contact-input {
  flex: 1;
  font-size: 28rpx;
  color: #333;
}

/* 底部按钮 */
.footer {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  gap: 20rpx;
  padding: 20rpx 30rpx 40rpx;
  background: #fff;
  border-top: 1rpx solid #eee;
}

.btn-cancel {
  flex: 1;
  height: 88rpx;
  line-height: 88rpx;
  background: #f5f5f5;
  color: #666;
  font-size: 30rpx;
  border-radius: 44rpx;
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0;
}

.btn-save {
  flex: 2;
  height: 88rpx;
  line-height: 88rpx;
  background: #ccc;
  color: #fff;
  font-size: 30rpx;
  border-radius: 44rpx;
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0;
}

.btn-save.active {
  background: #FF6B35;
}

.btn-save[disabled] {
  background: #ccc !important;
  color: #fff !important;
}
