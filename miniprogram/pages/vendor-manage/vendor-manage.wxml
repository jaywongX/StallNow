<view class="container">
  <!-- 加载中 -->
  <view wx:if="{{loading}}" class="loading-state">
    <view class="loading-icon"></view>
    <text class="loading-text">加载中...</text>
  </view>

  <!-- 摊位卡片 -->
  <view wx:if="{{!loading && stall}}" class="stall-card">
    <view class="card-header">
      <view class="stall-title">
        <text class="stall-name">{{stall.displayName}}</text>
        <text class="stall-status {{statusClass}}">{{statusText}}</text>
      </view>
      <text class="view-btn" bindtap="onViewDetail">查看详情 ></text>
    </view>

    <!-- 签到按钮区域 -->
    <view class="checkin-section" wx:if="{{stall.status !== 2}}">
      <view class="checkin-left">
        <text class="checkin-icon">📍</text>
        <text class="checkin-text" wx:if="{{!isTodayChecked}}">每天签到可让用户知道你的摊位还在</text>
        <text class="checkin-text checked" wx:else>✅ 今日已签到，明天再来吧！</text>
      </view>
      <button
        class="checkin-btn {{isTodayChecked ? 'checked' : ''}}"
        bindtap="onCheckIn"
        disabled="{{isTodayChecked}}"
      >
        {{isTodayChecked ? '已签到' : '签到'}}
      </button>
    </view>

    <view class="card-body">
      <view class="info-row">
        <text class="info-label">分类</text>
        <text class="info-value">{{stall.categoryName || '暂无'}}</text>
      </view>
      <view class="info-row">
        <text class="info-label">位置</text>
        <text class="info-value">{{stall.address || '暂无'}}</text>
      </view>
      <view class="info-row">
        <text class="info-label">出摊时间</text>
        <text class="info-value">{{stall.schedule ? stall.schedule.type : '暂无'}}</text>
      </view>
    </view>
  </view>

  <!-- 管理功能 -->
  <view wx:if="{{!loading && stall}}" class="manage-section">
    <view class="section-title">摊位管理</view>
    
    <view class="menu-list">
      <view class="menu-item" bindtap="onEditTap">
        <view class="menu-left">
          <text class="menu-icon">✏️</text>
          <text class="menu-name">编辑摊位信息</text>
        </view>
        <text class="menu-arrow">></text>
      </view>
      
      <view class="menu-item" bindtap="onShareTap">
        <view class="menu-left">
          <text class="menu-icon">📤</text>
          <text class="menu-name">分享我的摊位</text>
        </view>
        <text class="menu-arrow">></text>
      </view>
      
      <view class="menu-item" bindtap="onOfflineTap">
        <view class="menu-left">
          <text class="menu-icon">{{stall.status === 2 ? '▶️' : '⏸'}}</text>
          <text class="menu-name">{{stall.status === 2 ? '恢复摆摊' : '暂时不摆了'}}</text>
        </view>
        <text class="menu-arrow">></text>
      </view>
    </view>
  </view>

  <!-- 提示信息 -->
  <view wx:if="{{!loading && stall}}" class="tips-section">
    <text class="tips-title">💡 温馨提示</text>
    <text class="tips-text" wx:if="{{stall.status !== 2}}">
      建议每天签到一次，这样用户就知道你的摊位还在营业中。签到后，摊位状态会显示为"今日可能在"，更容易被找到哦～
    </text>
    <text class="tips-text" wx:if="{{stall.status === 2}}">
      你的摊位已下线，用户暂时看不到。恢复摆摊后记得签到，让用户更容易找到你。
    </text>
  </view>
  
  <!-- 小程序码弹窗 -->
  <view wx:if="{{showQRModal}}" class="modal-mask" bindtap="onCloseQRModal">
    <view class="modal-content qr-modal" catchtap="onModalContentTap">
      <view class="modal-header">
        <text class="modal-title">我的摊位码</text>
        <text class="modal-close" bindtap="onCloseQRModal">×</text>
      </view>
      
      <view class="modal-body qr-body">
        <view class="qr-section">
          <text class="qr-stall-name">{{stall.displayName}}</text>
          <text class="qr-hint">扫码查看摊位详情</text>
          
          <view class="qr-code-wrapper">
            <image 
              wx:if="{{qrCodeUrl}}"
              src="{{qrCodeUrl}}" 
              mode="aspectFit" 
              class="qr-code-image"
              show-menu-by-longpress
              binderror="onQRCodeError"
            />
            <view wx:elif="{{generatingQR}}" class="qr-loading">
              <view class="loading-icon"></view>
              <text>生成中...</text>
            </view>
            <view wx:else class="qr-placeholder" bindtap="generateQRCode">
              <text class="qr-retry-icon">🔄</text>
              <text>点击重新生成</text>
            </view>
          </view>
          
          <text class="qr-tips">💡 提示：可截图或保存后打印张贴在摊位上</text>
        </view>
      </view>
      
      <view class="modal-footer qr-footer">
        <button class="btn-cancel-modal" bindtap="onCloseQRModal">关闭</button>
        <button 
          wx:if="{{qrCodeUrl}}"
          class="btn-save-modal active" 
          bindtap="onSaveQRCode"
        >
          保存到相册
        </button>
      </view>
    </view>
  </view>
</view>
