/* 摊位管理页面样式 */

.container {
  min-height: 100vh;
  background: #F5F5F5;
  padding: 30rpx;
  box-sizing: border-box;
}

/* 加载状态 */
.loading-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding-top: 300rpx;
}

.loading-icon {
  width: 60rpx;
  height: 60rpx;
  border: 4rpx solid #f3f3f3;
  border-top: 4rpx solid #FF6B35;
  border-radius: 50%;
  animation: spin 1s linear infinite;
}

@keyframes spin {
  0% { transform: rotate(0deg); }
  100% { transform: rotate(360deg); }
}

.loading-text {
  margin-top: 20rpx;
  font-size: 28rpx;
  color: #999;
}

/* 摊位卡片 */
.stall-card {
  background: #fff;
  border-radius: 20rpx;
  padding: 30rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.05);
}

.card-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
  padding-bottom: 24rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.stall-title {
  display: flex;
  align-items: center;
}

.stall-name {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
  margin-right: 16rpx;
}

.stall-status {
  font-size: 24rpx;
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
}

.stall-status.active {
  background: #E6F7E6;
  color: #52C41A;
}

.stall-status.warning {
  background: #FFF7E6;
  color: #FAAD14;
}

.stall-status.expired,
.stall-status.offline {
  background: #F5F5F5;
  color: #999;
}

.view-btn {
  font-size: 26rpx;
  color: #FF6B35;
}

.card-body {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.info-row {
  display: flex;
  align-items: center;
}

.info-label {
  width: 140rpx;
  font-size: 28rpx;
  color: #999;
}

.info-value {
  flex: 1;
  font-size: 28rpx;
  color: #333;
}

/* 管理区域 */
.manage-section {
  margin-bottom: 30rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: 500;
  color: #333;
  margin-bottom: 20rpx;
  padding-left: 10rpx;
}

.menu-list {
  background: #fff;
  border-radius: 20rpx;
  overflow: hidden;
}

.menu-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 30rpx;
  border-bottom: 1rpx solid #f5f5f5;
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-left {
  display: flex;
  align-items: center;
}

.menu-icon {
  font-size: 36rpx;
  margin-right: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  height: 40rpx;
}

.menu-name {
  font-size: 30rpx;
  color: #333;
  display: flex;
  align-items: center;
  height: 40rpx;
}

.menu-arrow {
  font-size: 28rpx;
  color: #ccc;
}

.offline-item {
  border-top: 8rpx solid #f5f5f5;
}

.offline-text {
  color: #FF6B35;
}

.online-text {
  color: #52C41A;
}

/* 提示区域 */
.tips-section {
  background: #FFF7E6;
  border-radius: 16rpx;
  padding: 24rpx;
}

.tips-title {
  display: block;
  font-size: 28rpx;
  font-weight: 500;
  color: #FA8C16;
  margin-bottom: 12rpx;
}

.tips-text {
  display: block;
  font-size: 26rpx;
  color: #D48806;
  line-height: 1.6;
}

/* 弹窗样式 */
.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
}

.modal-content {
  width: 85%;
  max-width: 600rpx;
  background: #fff;
  border-radius: 24rpx;
  overflow: hidden;
}

.modal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 30rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.modal-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
}

.modal-close {
  font-size: 44rpx;
  color: #999;
  padding: 0 10rpx;
}

.modal-body {
  padding: 30rpx;
  max-height: 60vh;
  overflow-y: auto;
}

/* 时间选择 */
.schedule-options {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
  justify-content: center;
}

.schedule-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  width: 130rpx;
  height: 130rpx;
  background: #f9f9f9;
  border-radius: 16rpx;
  border: 2rpx solid transparent;
  transition: all 0.3s;
}

.schedule-item.active {
  background: #FFF5F2;
  border-color: #FF6B35;
}

.schedule-icon {
  font-size: 44rpx;
  margin-bottom: 8rpx;
}

.schedule-name {
  font-size: 26rpx;
  color: #666;
}

.schedule-item.active .schedule-name {
  color: #FF6B35;
}

/* 自定义时间 */
.custom-time-section {
  margin-top: 30rpx;
  padding: 20rpx;
  background: #f9f9f9;
  border-radius: 16rpx;
}

.time-picker-row {
  display: flex;
  align-items: center;
  justify-content: center;
}

.time-picker {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 20rpx 40rpx;
  background: #fff;
  border-radius: 12rpx;
  min-width: 140rpx;
}

.time-label {
  font-size: 24rpx;
  color: #999;
  margin-bottom: 8rpx;
}

.time-value {
  font-size: 32rpx;
  color: #333;
  font-weight: 500;
}

.time-separator {
  padding: 0 30rpx;
  font-size: 28rpx;
  color: #999;
}

/* 弹窗底部按钮 */
.modal-footer {
  display: flex;
  gap: 20rpx;
  padding: 20rpx 30rpx 40rpx;
  border-top: 1rpx solid #f0f0f0;
}

.btn-cancel-modal {
  flex: 1;
  height: 80rpx;
  line-height: 80rpx;
  background: #f5f5f5;
  color: #666;
  font-size: 28rpx;
  border-radius: 40rpx;
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0;
}

.btn-save-modal {
  flex: 1;
  height: 80rpx;
  line-height: 80rpx;
  background: #ccc;
  color: #fff;
  font-size: 28rpx;
  border-radius: 40rpx;
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0;
}

.btn-save-modal.active {
  background: #FF6B35;
}

.btn-save-modal[disabled] {
  background: #ccc !important;
  color: #fff !important;
}

/* 阻止冒泡 */
.modal-content {
  animation: modalIn 0.2s ease;
}

@keyframes modalIn {
  from {
    opacity: 0;
    transform: scale(0.9);
  }
  to {
    opacity: 1;
    transform: scale(1);
  }
}

/* 小程序码弹窗样式 */
.qr-modal {
  width: 80%;
}

.qr-body {
  padding: 40rpx;
}

.qr-section {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.qr-stall-name {
  font-size: 36rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 10rpx;
  text-align: center;
}

.qr-hint {
  font-size: 26rpx;
  color: #999;
  margin-bottom: 30rpx;
}

.qr-code-wrapper {
  width: 400rpx;
  height: 400rpx;
  background: #f9f9f9;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 30rpx;
  overflow: hidden;
}

.qr-code-image {
  width: 100%;
  height: 100%;
}

.qr-loading {
  display: flex;
  flex-direction: column;
  align-items: center;
  color: #999;
}

.qr-placeholder {
  display: flex;
  flex-direction: column;
  align-items: center;
  color: #999;
}

.qr-retry-icon {
  font-size: 48rpx;
  margin-bottom: 10rpx;
}

.qr-tips {
  font-size: 24rpx;
  color: #999;
  text-align: center;
  line-height: 1.5;
}

.qr-footer {
  justify-content: center;
}
